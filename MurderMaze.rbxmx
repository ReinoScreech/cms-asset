					<Item class="LocalScript" referent="RBX26834598F05F4B64A14AA0844D0587DF">
						<Properties>
							<ProtectedString name="Source"><![CDATA[--Local input script
local Services = setmetatable({}, {
	__index = function(self, key)
		local s = game:GetService(key)
		rawset(self, key, s)
		return s
	end
}) :: typeof(game)

local rs = game:GetService("RunService").RenderStepped
local function swait() rs:wait() end

Tool = script.Parent
Equipped = false

local mouse = Services.Players.LocalPlayer:GetMouse()
mouse.Move:Connect(function()
	if not Equipped then return end
	Tool.Input:FireServer("MouseMove",nil,mouse.Hit,mouse.Target)
end)

local function centerize(character)
	local camera = workspace.CurrentCamera
	local head = character:FindFirstChild("Head")
	if not head then return end

	local origin = head.Position
	local direction = camera.CFrame.LookVector * 500

	local raycastParams = RaycastParams.new()
	raycastParams.FilterDescendantsInstances = {character}
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude

	local result = workspace:Raycast(origin, direction, raycastParams)

	local hitPos = result and result.Position or (origin + direction)

	return CFrame.new(origin, hitPos), result and result.Instance or nil
end


Tool.Equipped:connect(function(mouse)
	local key_q = false
	local plr = game:GetService("Players").LocalPlayer
	local char = plr.Character
	local head:BasePart = char:findFirstChild("Head")
	if (head == nil) then return end
	
	Equipped = true
	
	--local hitPos, target:BasePart = centerize(char)
	if char:FindFirstChild("HumanoidRootPart") then
		Tool.Input:FireServer("MouseMove", nil, char.HumanoidRootPart.CFrame * CFrame.new(char.HumanoidRootPart.CFrame.LookVector * 3), nil)
	end
	
	mouse.Button1Down:connect(function() 
		if (key_q) then
			Tool.Input:FireServer("MouseR",true,mouse.Hit,mouse.Target) 
		else
			Tool.Input:FireServer("MouseL",true,mouse.Hit,mouse.Target) 
		end
	end)
	mouse.Button2Down:connect(function() 
		if ((head.Position - workspace.Camera.CFrame.Position).magnitude > 3) then return end
		Tool.Input:FireServer("MouseR",true,mouse.Hit,mouse.Target) 
	end)
	mouse.Button1Up:connect(function() 
		if (key_q) then
			Tool.Input:FireServer("MouseR",false,mouse.Hit,mouse.Target) 
		else
			Tool.Input:FireServer("MouseL",false,mouse.Hit,mouse.Target) 
		end
	end)
	mouse.Button2Up:connect(function() 
		if ((head.Position - workspace.Camera.CFrame.Position).magnitude > 3) then return end
		Tool.Input:FireServer("MouseR",false,mouse.Hit,mouse.Target) 
	end)
	mouse.KeyDown:connect(function(key) if (key:upper() == "Q") then key_q = true end Tool.Input:FireServer("Key"..key:upper(),true,mouse.Hit,mouse.Target) end)
	mouse.KeyUp:connect(function(key) if (key:upper() == "Q") then key_q = false end Tool.Input:FireServer("Key"..key:upper(),false,mouse.Hit,mouse.Target) end)
	--mouse.Move:connect(function() Tool.Input:FireServer("MouseMove",nil,mouse.Hit,mouse.Target) end)
end)

]]></ProtectedString>
