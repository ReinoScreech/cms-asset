		FakeHookBullet.Transparency = 1
		FakeHookBullet.CFrame = CFrame.new(LeftArm.CFrame.p,thiss)
		local Hook = Resources.Hook:Clone() Hook.Parent = FakeHookBullet
		local SpearWeld = WeldBetween({Part0 = FakeHookBullet, Part1 = Hook})

		thebeam.Attachment1 = Hook.Attachment
		local Grabbed = false
		for i = 1,60 do
			local Hit,Pos = Raycast(FakeHookBullet.Position,FakeHookBullet.CFrame.lookVector,5,Character)	
			TweenAnimate(FakeHookBullet,{CFrame = FakeHookBullet.CFrame*CFrame.new(0,0,-2.5)},.01,"Sine","InOut",0,false,0)	
			swait()	
			local Alpha,Easing,Direction,Repeat,Reverse,Delay = .35,'Sine','InOut',0,false,0
			TweenAnimate(FunnyRootJoint,{C0=cf(0,0,0)*angles(math.rad(-30.8),math.rad(0),math.rad(0))*RootCF},Alpha,Easing,Direction,Repeat,Reverse,Delay)
			TweenAnimate(FunnyLW,{C0=cf(-1.6,0.3,0.1)*angles(math.rad(92.4),math.rad(-21.2),math.rad(18.8))*LeftShoulderC0},.3,"Back","InOut",0,false,0)
			TweenAnimate(FunnyRW,{C0=cf(1.6,0.2,0.1)*angles(math.rad(86.9),math.rad(11.7),math.rad(40.2))*RightShoulderC0},Alpha,Easing,Direction,Repeat,Reverse,Delay)

			if Hit then
				RootPart.CanCollide = false
				RootPart.Anchored = true
				CamFOVStatus.Value = "HookFOV"
				CreateSound(Torso,8951373781,.5,math.random(10,15)/10)
				CreateSound(FakeHookBullet,8952857627,.5,math.random(10,15)/10)
				TweenAnimate(RootPart,{CFrame=FakeHookBullet.CFrame*CFrame.new(0,3,-2.5)},Alpha,Easing,Direction,Repeat,Reverse,Delay)
				TweenAnimate(Hook.Bolt,{Transparency=1},Alpha,Easing,Direction,Repeat,Reverse,Delay)
				Damage({Blood = true,Sound = 8952863605,Position = Hook.Bolt,MinDamage = 75, MaxDamage = 110, Magnitude = 7})
				Services.Debris:AddItem(FakeHookBullet,3)

				wait(.35)
				RootPart.Anchored = false
				RootPart.CanCollide = true
				break		
			end	
		end	

		delay(.1,function()	
			FakeHookBullet:Destroy()
			coroutine.resume(coroutine.create(function()	
				Hook:Destroy()
				funnyspearparticle:Destroy()
			end))
		end)	
		attack = false MoveLegs = false 
		coroutine.resume(coroutine.create(function()
			if canusehook == false then
				wait(.6)
				canusehook = true
			end
		end))
		CamFOVStatus.Value = "NoEFF"
	end
end

function mrclean()
	attack = true MoveLegs = true
	dirtyohnoo = false
	local bloodthing = Instance.new("Decal",LeftArm)
	bloodthing.Texture = "rbxassetid://1547472135"
	bloodthing.Face = "Bottom"
	bloodthing.Transparency = 1	
	bloodthing.Color3 = Color3.fromRGB(99, 0, 0)
	TweenAnimate(FunnyLW,{C0=cf(-1,-0.7,-1.1)*angles(math.rad(129.2),math.rad(2),math.rad(45.3))*LeftShoulderC0},.27,"Sine","InOut",0,false,0)
	TweenAnimate(FunnyRW,{C0=cf(1.4,0.1,-0.6)*angles(math.rad(92.5),math.rad(38.5),math.rad(-37.8))*RightShoulderC0},.27,"Sine","InOut",0,false,0)
	wait(.27)
	TweenAnimate(bloodthing,{Transparency=0},.27,"Sine","InOut",0,false,0)

	coroutine.resume(coroutine.create(function()
		wait(.57)
		TweenAnimate(bloodthing,{Transparency=1},1,"Sine","InOut",0,false,0)
		wait(.7)
		Services.Debris:AddItem(bloodthing,3)
	end))
	local juices = ToolModel.BloodiedBlade
	for i,v in pairs(juices:GetChildren()) do
		if v:IsA("Texture")  then
			TweenAnimate(v,{Transparency=1},.35,"Sine","InOut",0,false,0)
		elseif v:IsA("ParticleEmitter")  then
			v.Enabled = false
		end
	end
	Humanoid.Health = Humanoid.Health - 15
	add:BloodDrop(ToolModel.Blade.CFrame,Vector3.new(math.random(-10,10),math.random(25,25),math.random(-10,10)),math.random(11,15)/100,3,{MainModel,cam,ToolModel},EffectModel)

	CreateSound(Torso,6330975034,.5,math.random(10,15)/10)	
	CreateSound(Torso,6331618544,.5,math.random(10,15)/10)	
	TweenAnimate(FunnyLW,{C0=cf(-1.3,-0.2,0.3)*angles(math.rad(111),math.rad(-15.7),math.rad(-37.3))*LeftShoulderC0},.25,"Back","InOut",0,false,0)
	TweenAnimate(FunnyRW,{C0=cf(1.4,0.2,-0.6)*angles(math.rad(87.8),math.rad(47.4),math.rad(-33.1))*RightShoulderC0},.25,"Back","InOut",0,false,0)
	wait(.25)

	attack = false MoveLegs = false
end


function slid()
	if canslide == true then
		attack = true
		canslide = false
		FunnyLH.Enabled = true
		FunnyRH.Enabled = true
		smokt.Enabled = true
		CreateSound(Torso,7017945948,.5,math.random(10,15)/10,{MaxDistance = 150})	
		local Alpha,Easing,Direction,Repeat,Reverse,Delay = .2,'Sine','InOut',0,false,0
		TweenAnimate(FunnyRootJoint,{C0=cf(-0.6,-1.6,0.7)*angles(math.rad(52),math.rad(-50.3),math.rad(-8.3))*RootCF},.25,'Back','InOut',0,false,0)
		TweenAnimate(FunnyLH,{C0=cf(-1,-1,0)*angles(math.rad(3.2),math.rad(25.3),math.rad(-2.2))*angles(math.rad(0),math.rad(-90),math.rad(0))},Alpha,Easing,Direction,Repeat,Reverse,Delay)
		TweenAnimate(FunnyRH,{C0=cf(1,-0.9,-0.2)*angles(math.rad(20.5),math.rad(0),math.rad(0))*angles(math.rad(0),math.rad(90),math.rad(0))},Alpha,Easing,Direction,Repeat,Reverse,Delay)
		TweenAnimate(FunnyLW,{C0=cf(-1.4,0.5,0.3)*angles(math.rad(35),math.rad(25),math.rad(-20))*LeftShoulderC0},Alpha,Easing,Direction,Repeat,Reverse,Delay)
		TweenAnimate(FunnyRW,{C0=cf(1.5,0.5,0)*angles(math.rad(108.3),math.rad(0),math.rad(0))*RightShoulderC0},Alpha,Easing,Direction,Repeat,Reverse,Delay)
		TweenAnimate(FunnyNeck,{C0 =necko*angles(math.rad(52.7),math.rad(16),math.rad(10.9))},Alpha,Easing,Direction,Repeat,Reverse,Delay)

		local slide = Instance.new("BodyVelocity")
		slide.Parent = RootPart
		slide.MaxForce = Vector3.new(1 * 10000,0,1 * 10000)
		slide.Velocity = Character.HumanoidRootPart.CFrame.lookVector * 140	
		Head.CanCollide = false
		for count = 1, 3 do
			wait(0.1)
			slide.Velocity*= 0.7
		end

		slide:Destroy()
		FunnyLH.Enabled = false
		FunnyRH.Enabled = false
		smokt.Enabled = false
		attack = false
		coroutine.resume(coroutine.create(function()
			if canslide == false then
				wait(.6)
				canslide = true
			end
		end))
	end
end


