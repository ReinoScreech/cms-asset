					if a.Name == "Neck" or h.Name == "Neck" then h.LimitsEnabled=true h.TwistUpperAngle=15 elseif a.Name ~= "Neck" or h.Name ~= "Neck" then h.TwistUpperAngle=90 end
					local a1=Instance.new("Attachment",ainfo[4]) a1.CFrame=ainfo[1]
					local a2=Instance.new("Attachment",ainfo[5]) a2.CFrame=ainfo[2]
					h.Attachment0=a1 h.Attachment1=a2
				elseif f==true and a.Name ~= "Neck" and a.Name ~= "Left Hip" and a.Name ~= "Right Hip" and a.Name ~= "LeftHip" and a.Name ~= "RightHip" and a.Name ~= "LeftShoulder" and a.Name ~= "RightShoulder" and a.Name ~= "Left Shoulder" and a.Name ~= "Right Shoulder" then
					local ainfo = {a.C0,a.C1,a.Parent,a.Part0,a.Part1,a.Name}
					local h=Instance.new("BallSocketConstraint",ainfo[3]) h.Name=ainfo[6]
					if a.Name == "Neck" or h.Name == "Neck" then h.LimitsEnabled=true h.TwistUpperAngle=15 elseif a.Name ~= "Neck" or h.Name ~= "Neck" then h.TwistUpperAngle=90 end
					local a1=Instance.new("Attachment",ainfo[4]) a1.CFrame=ainfo[1]
					local a2=Instance.new("Attachment",ainfo[5]) a2.CFrame=ainfo[2]
					h.Attachment0=a1 h.Attachment1=a2
				end
				a:Destroy()	
			elseif a:IsA'Weld' or a:IsA'ManualWeld' then
				if a.Parent.Size == Vector3.new(2,2,1) or a.Parent.Size == Vector3.new(2,2.1,1) or a.Parent.Size == Vector3.new(1,1.105,1) or a.Parent.Size == Vector3.new(1,1.227,1) or a.Parent.Size == Vector3.new(1,1.253,1) or a.Parent.Size == Vector3.new(1,1.277,1) or a.Parent.Size == Vector3.new(1,2,1) or a.Parent.Size == Vector3.new(2,1,1) or a.Parent.Name == "Head" or a.Parent.Name == "Torso" or a.Parent.Name == "Right Arm" or a.Parent.Name == "Left Arm" or a.Parent.Name == "Right Leg" or a.Parent.Name == "Left Leg" or a.Parent.Name == "UpperTorso" or a.Parent.Name == "HumanoidRootPart" or a.Parent.Name == "LowerTorso" or a.Parent.Name == "RightHand" or a.Parent.Name == "LeftHand" or a.Parent.Name == "RightFoot" or a.Parent.Name == "LeftFoot" or a.Parent.Name == "LeftUpperArm" or a.Parent.Name == "LeftLowerArm" or a.Parent.Name == "RightUpperArm" or a.Parent.Name == "RightLowerArm" or a.Parent.Name == "LeftUpperLeg" or a.Parent.Name == "LeftLowerLeg" or a.Parent.Name == "RightUpperLeg" or a.Parent.Name == "RightLowerLeg" then
					if t==true and h==false and f==false and a.Name ~= "Waist" and a.Name ~= "Left Hip" and a.Name ~= "Right Hip" then
						local ainfo = {a.C0,a.C1,a.Parent,a.Part0,a.Part1,a.Name}
						local h=Instance.new("BallSocketConstraint",ainfo[3]) h.Name=ainfo[6]
						if a.Name == "Neck" or h.Name == "Neck" then h.LimitsEnabled=true h.TwistUpperAngle=15 elseif a.Name ~= "Neck" or h.Name ~= "Neck" then h.TwistUpperAngle=90 end
						local a1=Instance.new("Attachment",ainfo[4]) a1.CFrame=ainfo[1]
						local a2=Instance.new("Attachment",ainfo[5]) a2.CFrame=ainfo[2]
						h.Attachment0=a1 h.Attachment1=a2
					elseif t==false and h==true and f==false and a.Name ~= "Neck" then
						local ainfo = {a.C0,a.C1,a.Parent,a.Part0,a.Part1,a.Name}
						local h=Instance.new("BallSocketConstraint",ainfo[3]) h.Name=ainfo[6]
						if a.Name == "Neck" or h.Name == "Neck" then h.LimitsEnabled=true h.TwistUpperAngle=15 elseif a.Name ~= "Neck" or h.Name ~= "Neck" then h.TwistUpperAngle=90 end
						local a1=Instance.new("Attachment",ainfo[4]) a1.CFrame=ainfo[1]
						local a2=Instance.new("Attachment",ainfo[5]) a2.CFrame=ainfo[2]
						h.Attachment0=a1 h.Attachment1=a2
					elseif h==true and t==true and f==false and a.Name ~= "Neck" and a.Name ~= "Waist" and a.Name ~= "Left Hip" and a.Name ~= "Right Hip" then
						local ainfo = {a.C0,a.C1,a.Parent,a.Part0,a.Part1,a.Name}
						local h=Instance.new("BallSocketConstraint",ainfo[3]) h.Name=ainfo[6]
