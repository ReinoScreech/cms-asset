								</Item>
								<Item class="Script" referent="RBXB6DD4C49644945AFA91020A82AF57BDF">
									<Properties>
										<ProtectedString name="Source"><![CDATA[local character = script.Parent
--local invalidations = {"BodyVelocity", "AngularVelocity", "LinearVelocity", "BodyAngularVelocity", "BodyThrust", "BodyGyro", "BodyForce", "BodyMover"}
--[[task.delay(0.2, function()
	for _,obj:Instance in pairs(character:GetDescendants()) do
		if table.find({invalidations}, obj.ClassName) then
			task.defer(pcall, game.Destroy, obj)
		end
	end
end) currently handled in functions ]]

local connection = character.DescendantAdded:Connect(function(d)
	if d:IsA("BallSocketConstraint") or d:IsA("HingeConstraint") or d:IsA("RopeConstraint") or d:IsA("UnionOperation") or d:IsA("Glue") or d:IsA("ManualGlue") then
		task.defer(pcall, game.Destroy, d)
	end
end)

while task.wait() do
	if character == nil then
		connection:Disconnect()
		break
	end
end]]></ProtectedString>
