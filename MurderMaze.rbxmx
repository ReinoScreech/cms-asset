		 |  _ \ _ __ ___ (_) ___  ___| |_(_) | ___| |   (_) |__  
		 | |_) | '__/ _ \| |/ _ \/ __| __| | |/ _ \ |   | | '_ \ 
		 |  __/| | | (_) | |  __/ (__| |_| | |  __/ |___| | |_) |
		 |_|   |_|  \___// |\___|\___|\__|_|_|\___|_____|_|_.__/ 
		               |__/                                      
		
			By VolcanoINC
			Created mid-2015
]]

--Define the Projectile table and allow me to add metamethods to it.
local Services = setmetatable({}, {
	__index = function(self, key)
		local s = game:GetService(key)
		rawset(self, key, s)
		return s
	end
}) :: typeof(game)

local Projectile = {}
Projectile.__index = Projectile

--A counting variable that counts how many projectiles have been fired
local id = 0
local tag = require(game:GetService("ServerScriptService"):FindFirstChild("Tagging",1))

--Some visual debugging functions
--Displays a vector (and its direction) as an arrow of a specified color pointing in a specific direction
function displayVector(origin,dir,col,t)
	local p = Instance.new("Part")
	p.FormFactor = Enum.FormFactor.Custom
	p.TopSurface = Enum.SurfaceType.Smooth
	p.BottomSurface = Enum.SurfaceType.Smooth
	p.Size = Vector3.new(0.2,0.2,dir.magnitude)
	p.CFrame = CFrame.new(origin+dir/2,origin+dir)
	p.BrickColor = col
	p.Transparency = t
	p.Anchored = true
	p.CanCollide = false
	p.Parent = workspace
	
	local q = Instance.new("Part")
	q.FormFactor = Enum.FormFactor.Custom
	q.TopSurface = Enum.SurfaceType.Smooth
	q.BottomSurface = Enum.SurfaceType.Smooth
	q.Size = Vector3.new(0.2,0.2,2)
	q.CFrame = ((p.CFrame * CFrame.new(0,0,-dir.magnitude/2)) * CFrame.Angles(0,math.pi/4,0)) * CFrame.new(0,0,1)
	q.BrickColor = col
	q.Transparency = t
	q.Anchored = true
	q.CanCollide = false
	q.Parent = p
	
	local q = Instance.new("Part")
	q.FormFactor = Enum.FormFactor.Custom
	q.TopSurface = Enum.SurfaceType.Smooth
	q.BottomSurface = Enum.SurfaceType.Smooth
	q.Size = Vector3.new(0.2,0.2,2)
	q.CFrame = ((p.CFrame * CFrame.new(0,0,-dir.magnitude/2)) * CFrame.Angles(0,-math.pi/4,0)) * CFrame.new(0,0,1)
	q.BrickColor = col
	q.Transparency = t
	q.Anchored = true
	q.CanCollide = false
	q.Parent = p
	
	return p
end

--Displays a plane as a flat square with the given normal
function displayPlane(pos,normal,indicatorsize,col,t)
	local p = Instance.new("Part")
	p.FormFactor = Enum.FormFactor.Custom
	p.TopSurface = Enum.SurfaceType.Smooth
	p.BottomSurface = Enum.SurfaceType.Smooth
	p.Size = Vector3.new(0.2,0.2,0.2)
	p.CFrame = CFrame.new(pos,pos+normal)
	p.BrickColor = col
	p.Transparency = t
	p.Anchored = true
	p.CanCollide = false
	p.Parent = workspace
	
	local m = Instance.new("BlockMesh")
	m.Scale = Vector3.new(indicatorsize*5,indicatorsize*5,0)
	m.Parent = p
	
	displayVector(pos,normal*indicatorsize,col,t).Parent = p
	
	return p
end

--A function that calculates line-plane intersections. Used for bullet penetration/piercing.
--Returns whether or not the line intersects the plane and the position at which the intersection occurs
function linePlaneIntersect(u,P0,n,V0)
	local w = V0-P0
	local SI = n:Dot(w)/n:Dot(u)
	return (SI >= 0 and SI <= 1),(P0 + u*SI)
end

--Built-in Projectile Handler: For when you *really* don't want to handle them in your own code.
local builtInHandler = false
local Projectiles = {}
function Projectile.runHandler()
	if (builtInHandler) then return end
	builtInHandler = true
	spawn(function()
		while true do
			local delta = wait()
			for i=#Projectiles,1,-1 do
				if Projectiles[i].useHandler and not Projectiles[i]:step(delta) then
					table.remove(Projectiles,i):Destroy()
				end
			end
		end
	end)
end

--A model instance to contain all parts created by the simulation (tracers, particles)
local projectileModel = Instance.new("Model",workspace)
projectileModel.Name = "ProjectileLibItems"


--Projectile constructor
--Arguments are:
--	Tool		: INSTANCE	: 	The tool the projectile was fired from. The parent of the tool is ignored in any bullet collision detection.
--	pos1		: VECTOR3	: 	The origin of the projectile. The projectile will be fired from this position
--	pos2		: VECTOR3	: 	Deprecated property. Used to be the "target position" of the projectile. No longer does anything.
--	dir			: VECTOR3	:	The direction in which the projectile is to be fired. Is normalized.
--	speed		: NUMBER	:	The muzzle velocity of the projectile, in studs/sec
--	rspeed		: NUMBER	: 	The rotational velocity of the projectile. For projectiles that use spin stabilization. Causes bullets 
--									to drift off to the side on long shots.
--	damage		: NUMBER	:	The amount of damage done to humanoids at point-blank range (depends on the projectile velocity on impact)
--	force		: NUMBER	:	A force multiplier to the amount of force exerted to objects when the projectile impacts.
--	penPower	: NUMBER	: 	A multiplier to the amount of distance a projectile can penetrate a given material. 
--	useHandler	: BOOLEAN	:	Tells the projectile that it should use the built-in handler.

function Projectile.new(Tool,pos1,pos2,dir,speed,rspeed,damage,force,penPower,useHandler,tagger)
	local new = {}
	
	local cframe = CFrame.new(pos1,pos1+dir)
	local vel = dir.unit * speed
	
	local delta = 1/30
	
	local prevcf = cframe
	
	local tracer = Instance.new("Part")
	tracer.TopSurface = "Smooth"
	tracer.BottomSurface = "Smooth"
	tracer.Anchored = true
	tracer.CanCollide = false
	tracer.Size = Vector3.new(0.2,0.2,0.2)
	tracer.BrickColor = BrickColor.new("Bright orange")
	tracer.Material = Enum.Material.Neon
	tracer.Parent = projectileModel
	
	Instance.new("BlockMesh",tracer)
	
	new.cframe = cframe
	new.vel = vel
	new.muzzlevel = speed
	new.prevcf = prevcf
	new.tracer = tracer
	new.Tool = Tool
	new.rspeed = rspeed
	new.damage = damage
	new.force = force or 1
	new.penPower = penPower or 1
	new.Steps = 60
	new.OnHitCallback = nil
	new.id = id
	new.useHandler = useHandler
	new.tagger = tagger
	
	id = id + 1
	setmetatable(new,Projectile)
	
	if (useHandler) then
		table.insert(Projectiles,new)
		if (not builtInHandler) then
			Projectile.runHandler()
		end
	end
	
	return new,"PRJ#" .. id
end

--Function to add a clone of the module for those who want to require by ID but use the module in LocalScripts
function Projectile.insertModuleInto(instance)
	local clone = script:clone()
	clone.Parent = instance
	return clone
end

--The maximum angle for a ricochet if the hit material has a density of 1
local maxRicochetAngle = math.cos(math.rad(90-20))

--A method to set an on-hit callback function.
function Projectile:setOnHitCallback(func)
	self.OnHitCallback = func
end

--Method to set the lifespan of a projectile
function Projectile:setLifespan(lifespan)
	self.Steps = lifespan
end

--Method to modify/disable the tracer beam
function Projectile:setTracerEnabled(enabled)
	self.tracer.Parent = enabled and workspace or nil
end

--Utility function to find the first child of a given class
local function findFirstByClass(dir,class)
	for _,i in pairs(dir:children()) do
		if (i:IsA(class)) then return i end
	end
	return nil
end

local function getMaterialGroup(part,material)
	if (part.Parent and findFirstByClass(part.Parent,"Humanoid")) then return "Humanoid" end
	if (material == Enum.Material.Concrete) then return "Rock" end
	if (material == Enum.Material.Rock) then return "Rock" end
	if (material == Enum.Material.Slate) then return "Rock" end
	if (material == Enum.Material.Marble) then return "Rock" end
	if (material == Enum.Material.Granite) then return "Rock" end
	if (material == Enum.Material.Cobblestone) then return "Rock" end
	if (material == Enum.Material.Asphalt) then return "Rock" end
	if (material == Enum.Material.CrackedLava) then return "Rock" end
	if (material == Enum.Material.Pavement) then return "Rock" end
	if (material == Enum.Material.Grass) then return "Dirt" end
	if (material == Enum.Material.Sand) then return "Dirt" end
	if (material == Enum.Material.Mud) then return "Dirt" end
	if (material == Enum.Material.LeafyGrass) then return "Dirt" end
	if (material == Enum.Material.Limestone) then return "Dirt" end
	if (material == Enum.Material.Salt) then return "Dirt" end
	if (material == Enum.Material.Sandstone) then return "Dirt" end
	if (material == Enum.Material.Pebble) then return "Dirt" end
	if (material == Enum.Material.Snow) then return "Dirt" end
	if (material == Enum.Material.CorrodedMetal) then return "Metal" end
	if (material == Enum.Material.DiamondPlate) then return "Metal" end
	if (material == Enum.Material.Metal) then return "Metal" end
	if (material == Enum.Material.Foil) then return "Metal" end
	if (material == Enum.Material.Wood) then return "Wood" end
	if (material == Enum.Material.WoodPlanks) then return "Wood" end
	if (material == Enum.Material.Plastic) then return "Plastic" end
	if (material == Enum.Material.SmoothPlastic) then return "Plastic" end
	if (material == Enum.Material.Ice) then return "Ice" end
	if (material == Enum.Material.Glacier) then return "Ice" end
	if (material == Enum.Material.Neon) then return "Ice" end
	return nil
end

--Utility function to create an on-hit particle effect
local function hitParticles(part,pos,normal,material)
	local material = getMaterialGroup(part,material)
	if (material) then
		local spawner = script.Resources.HitParticles:FindFirstChild(material)
		if (spawner) then
			local pt = spawner:clone()
			pt.CFrame = CFrame.new(pos,pos+normal)
			pt.Parent = projectileModel
			
			coroutine.wrap(function()
				wait()
				if pt.ParticleEmitter.Normalize.Value then
					pt.ParticleEmitter.Color = ColorSequence.new(part.BrickColor.Color)
				end
				
				if (pt:FindFirstChild("BulletHole")) then
					if not part.Anchored then
						local weld = Instance.new("Weld", pt)
						weld.Part0 = pt
						weld.Part1 = part
						weld.C0 = pt.CFrame:inverse() * part.CFrame
						pt.Anchored = false
					end
					
					pt.BulletHole.ImageLabel.ImageColor3 = part.BrickColor.Color
				end
				
				pt.ParticleEmitter:Emit(32)
				pt["Sound" .. math.random(1,4)]:play()
			end)()
			
			local deb = game:GetService("Debris")
			deb:AddItem(pt,10)
			return pt
		end
	end
end

--Projectile Step method
function Projectile:step(delta)
	self.Steps = self.Steps - 1
	
	if (projectileModel == nil or projectileModel.Parent ~= workspace) then
		projectileModel = Instance.new("Model",workspace)
		projectileModel.Name = "ProjectileLibItems"
	end
	
	--The projectile should be destroyed after passing its lifespan
	if (self.Steps < 0) then return false end
	
	--Deal with bullet motion
	--Basic gravity
	self.cframe = self.cframe + self.vel*delta
	self.vel = self.vel - Vector3.new(0,workspace.Gravity*delta,0)
	
	--Drag
	self.vel = self.vel - self.vel*delta*0.1
	
	--Rotational drift
	local x,y,z,
			a,b,c,
			d,e,f,
			g,h,i = self.cframe:components()
	
	local right = Vector3.new(a,d,g)
	local up = Vector3.new(b,e,h)
	local lvel = self.cframe:vectorToObjectSpace(self.vel)
	self.vel = self.vel - delta*(right*lvel.y - up*lvel.x) * self.rspeed / 20
	
	--The ray used in all raycasts in this step
	local ray = Ray.new(self.prevcf.p,(self.cframe.p-self.prevcf.p))
	
	--A table containing all parts to be ignored. Parts will be added by subsequent raycasts in order to handle bullet penetration.
	local ignorelist = {projectileModel}
	if (typeof(self.Tool) == "Instance") then
		ignorelist[2] = self.Tool.Parent
	elseif (type(self.Tool) == "table") then
		ignorelist = self.Tool
		ignorelist[#ignorelist+1] = projectileModel
	end
	
	--This loop will continue to cast rays until the current raycast length either hits nothing or the bullet velocity drops below 10 studs/sec
	local part,pos,normal,material
	while true do
		--Doing the actual raycast
		part,pos,normal,material = workspace:FindPartOnRayWithIgnoreList(ray,ignorelist)
		
		table.insert(ignorelist,part)
		
		--Check if a part was hit. Return if nothing was hit.
		if (part) then
			--Make sure the part isn't a hat, and ignore it if it is (added because hats were OP armor)
			if (part.Parent and not part.Parent:IsA("Accoutrement")) then
				
				--Check if we hit a humanoid
				local hum = findFirstByClass(part.Parent,"Humanoid")
				if (hum) then
					if tag then tag.TagHumanoid(hum,self.tagger) end
					--Deal damage to the hit humanoid, double damage on headshots.
					if (part.Name == "Head") then
						hum.Health = hum.Health - (self.vel.magnitude/self.muzzlevel) * self.damage * 2
						
						--If the humanoid has godmode but the bullet got a headshot, kill anyways.
						if (hum.MaxHealth == math.huge) then
							part:breakJoints() --Kill them anyways
						end
					else
						hum.Health = hum.Health - (self.vel.magnitude/self.muzzlevel) * self.damage
					end
					
					pcall(function()
						local victimPlayer = Services.Players:GetPlayerFromCharacter(part.Parent)
						local me = Services.Players:GetPlayerFromCharacter(self.tagger)
						local remote = game:GetService("ReplicatedStorage"):WaitForChild("Shared").Remote
						local gamestatus = game:GetService("ReplicatedStorage"):WaitForChild("Shared").GameStatus

					if victimPlayer then
						warn("revolver hit",victimPlayer,me,remote,gamestatus)
							if hum.Health > 0 then
								if gamestatus.Vigilante.Value == me then
									remote.VisualCall:FireClient(victimPlayer, "dialogue", "shotByVig")
									remote.VisualCall:FireAllClients("playerSpoke", victimPlayer, "shotByVig")
									if victimPlayer ~= gamestatus.Killer.Value then
										remote.VisualCall:FireClient(me, "dialogue", "hurtInnocent")
										remote.VisualCall:FireAllClients("playerSpoke", me, "hurtInnocent")
									end
								end
							end
						end
					end)
				end
				
				--Calculate the density of the part that was hit
				local density = part:GetMass()/(part.Size.x*part.Size.y*part.Size.z)
				
				--Decide, based on velocity and density, whether the projectile should bounce or penetrate
				local dot = normal:Dot(self.vel.unit)
				dot = dot * (10 / density) * (self.vel.magnitude / 2400)
				
				if (math.abs(dot) <= maxRicochetAngle) then
					--The projectile fulfilled the requirements for a ricochet
					--Calculate the new velocity of the projectile
					self.vel = (self.vel - normal*normal:Dot(self.vel)*2) * math.min(density/10,0.5)
					self.cframe = CFrame.new(pos) * CFrame.Angles(
						math.random()*2*math.pi,
						math.random()*2*math.pi,
						math.random()*2*math.pi
					)
					
					--CFrame.new(pos,pos+self.vel)
					
					--Apply a force to the hit part based on the change in velocity
					do
						local pt = part
						local position = pos
						local deb = game:GetService("Debris")
						local force = Instance.new("BodyThrust")
						local F = pt.CFrame:vectorToObjectSpace(normal*normal:Dot(self.vel)*2) * self.force
						
						force.Force = F
						force.Location = pt.CFrame:toObjectSpace(CFrame.new(position)).p
						force.Name = "BulletForce"
						force.Parent = pt
						
						--Call the particle spawn function
						hitParticles(part,pos,normal,material)
						
						--Call the on-hit callback function if there is one
						if (self.OnHitCallback) then
							coroutine.wrap(function()
								self.OnHitCallback(pt,pos,F,"Bounce",self.vel)
							end)()
						end
						
						deb:AddItem(force,0.1)
					end
				else
					--Calculate the distance of the projectile within the medium
					local x,y,z,
							a,b,c,
							d,e,f,
							g,h,i = part.CFrame:components()
					
					--Get surface normals of the part
					local n1 = Vector3.new(a,d,g).unit
					local n2 = Vector3.new(b,e,h).unit
					local n3 = Vector3.new(c,f,i).unit
					local n4,n5,n6 = -n1,-n2,-n3
					
					local pos1 = part.Position + n1 * (part.Size.x/2)
					local pos2 = part.Position + n2 * (part.Size.y/2)
					local pos3 = part.Position + n3 * (part.Size.z/2)
					local pos4 = part.Position + n4 * (part.Size.x/2)
					local pos5 = part.Position + n5 * (part.Size.y/2)
					local pos6 = part.Position + n6 * (part.Size.z/2)
					
					local distance,outnormal = math.huge,Vector3.new(0,0,1)
					
					--Find the exit surface
					if (n1:Dot(self.vel) >= 0) then local intersect,coord = linePlaneIntersect(ray.Direction,ray.Origin,n1,pos1) local mag = (coord-pos).magnitude if (intersect and mag < distance) then distance,outnormal = mag,n1 end end
					if (n2:Dot(self.vel) >= 0) then local intersect,coord = linePlaneIntersect(ray.Direction,ray.Origin,n2,pos2) local mag = (coord-pos).magnitude if (intersect and mag < distance) then distance,outnormal = mag,n2 end end
					if (n3:Dot(self.vel) >= 0) then local intersect,coord = linePlaneIntersect(ray.Direction,ray.Origin,n3,pos3) local mag = (coord-pos).magnitude if (intersect and mag < distance) then distance,outnormal = mag,n3 end end
					if (n4:Dot(self.vel) >= 0) then local intersect,coord = linePlaneIntersect(ray.Direction,ray.Origin,n4,pos4) local mag = (coord-pos).magnitude if (intersect and mag < distance) then distance,outnormal = mag,n4 end end
					if (n5:Dot(self.vel) >= 0) then local intersect,coord = linePlaneIntersect(ray.Direction,ray.Origin,n5,pos5) local mag = (coord-pos).magnitude if (intersect and mag < distance) then distance,outnormal = mag,n5 end end
					if (n6:Dot(self.vel) >= 0) then local intersect,coord = linePlaneIntersect(ray.Direction,ray.Origin,n6,pos6) local mag = (coord-pos).magnitude if (intersect and mag < distance) then distance,outnormal = mag,n6 end end
					
					--Calculate the drag force the material exerts on the projectile
					local slower = self.vel.unit*math.min(1000*distance*density/self.penPower,self.vel.magnitude)
					self.vel = self.vel - slower
					
					--Calculate exit point
					local pExit = pos+ray.Direction.unit*distance
					
					--Place the projectile at a point corresponding to the new velocity
					--Also rotate it randomly (random behavior after travelling through a solid)
					local pNew = pos+self.vel*delta
					self.cframe = CFrame.new(pNew) * CFrame.Angles(
						math.random()*2*math.pi,
						math.random()*2*math.pi,
						math.random()*2*math.pi
					)
					
					--Apply a reaction force to the part
					do
						local pt = part
						local position = pos
						local deb = game:GetService("Debris")
						local force = Instance.new("BodyThrust")
						local F = pt.CFrame:vectorToObjectSpace(slower) * self.force
						
						force.Force = F
						force.Location = pt.CFrame:toObjectSpace(CFrame.new(position)).p
						force.Name = "BulletForce"
						force.Parent = pt
						
						--Call up the on-hit callback function if there is one
						if (self.OnHitCallback) then
							if (self.vel.magnitude >= 10) then
								local pEntry = pos
								coroutine.wrap(function()
									self.OnHitCallback(pt,pos,F,"Pierce",self.vel,pEntry,pExit)
								end)()
							else
								coroutine.wrap(function()
									self.OnHitCallback(pt,pos,F,"Stop",self.vel)
								end)()
							end
						end
						
						--Call particle spawn function
						if (self.vel.magnitude >= 10) then
							local pEntry = pos
							hitParticles(part,pEntry,normal,material)
							hitParticles(part,pExit,outnormal,material)
						else
							hitParticles(part,pos,normal,material)
						end
						
						deb:AddItem(force,0.1)
					end
				end
			end
		else
			--We hit nothing, so exit the loop
			break
		end
		--Exit if the projectile slowed down too much
		if (self.vel.magnitude < 10) then break end
	end
	
	--Move the tracer 
	self.tracer.Mesh.Scale = Vector3.new(1,1,(self.cframe.p-self.prevcf.p).magnitude*5)
	self.tracer.CFrame = CFrame.new((self.prevcf.p+self.cframe.p)/2,self.cframe.p)
	self.tracer.Velocity = self.vel
	self.prevcf = self.cframe
	
	--Return false if the bullet should stop
	if (self.vel.magnitude < 10) then return false end
	
	--Return true if the bullet should continue
	return true
end

--Projectile destroy method
function Projectile:Destroy()
	self.tracer:Destroy()
end

return Projectile
