Tool.Remote.OnServerEvent:Connect(function(a,type,code,args)
	if code == 1 and ToolEnabled==true and attack == false then
		player = a
		if type=="Slash"  then
			sla()
		end
		if type=="Heavy" then
			heav()
		end
		--	if type=="Slide" and canslide == true then
		--slid()
		--		not used
		--		end
		if type=="Hook"  then
			Hook(args)

		end
		if type=="Inspect"  then
			inspectwhat()

		end
		if type=="Kick" and IsCrouching == false then
			kick()

		end
		if type=="DKick" and IsCrouching == false then
			dropkick()

		end
		if type=="Clean"  then
			if dirtyohnoo == true then
				mrclean()

			end
		end

		if type=="ToggleCrouch" then
			if IsCrouching == false then
				IsCrouching = true
				Status = "Crouching"
				Head.CanCollide = false
			elseif IsCrouching == true then
				IsCrouching = false	
				Status = "Standing"
				Head.CanCollide = true
			end
		end
		---experimental
		if type=="Run"  then
			Humanoid.WalkSpeed = 25

		end
		if type=="Walk"  then
			Humanoid.WalkSpeed = 18

		end
	end
end)

