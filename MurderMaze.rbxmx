				<Item class="LocalScript" referent="RBX97FB819A221349FCB4DC267ED9D9CEFB">
					<Properties>
						<ProtectedString name="Source"><![CDATA[--!strict
local plr = game:GetService("Players").LocalPlayer
local chr = plr.Character or plr.CharacterAdded:Wait()

local tweenService = game:GetService("TweenService")

local remote = game:GetService("ReplicatedStorage"):WaitForChild("Shared").Remote
local gamestatus = game:GetService("ReplicatedStorage"):WaitForChild("Shared").GameStatus

local ui = script.Parent
local dialogue = require(script:WaitForChild("Dialogue"))
local dialoguelabel = ui:WaitForChild("dialogue")

local playing = plr:GetAttribute("Playing")

local role = "survivor"
local personality = "panicked"

local plrRoles = {}
local plrPersonalities = {}

local rolestrokecolors = {
	killer = {
		main = Color3.fromRGB(255, 133, 135),
		stroke = Color3.fromRGB(120, 0, 2)
	},
	vigilante = {
		main = Color3.fromRGB(130, 159, 255),
		stroke = Color3.fromRGB(0, 2, 120)
	},
	survivor = {
		main = Color3.fromRGB(148, 255, 149),
		stroke = Color3.fromRGB(2, 120, 0)
	}
}

--//                  funcs

--// dialogue stuff
local twl = 0
local function typewrite(label, text, speed, sound, soundparent)
	label.Text = ""
	twl += 1
	for i = 1, #text do
		local current = twl
		if twl ~= current then break end
		label.Text = string.sub(text, 1, i)
		task.spawn(function()
			local snd = sound and sound:IsA("Sound") and sound:Clone() or script.noise:Clone()
			snd.Parent = soundparent or game:GetService("SoundService")
			snd:Play()
			task.delay(snd.TimeLength + 2, function()
				snd:Destroy()
			end)
		end)
		task.wait(speed or 0.02)
	end
end

local function chooseLine(role,key)
	return dialogue and dialogue[role] and dialogue[role][key] and dialogue[role][key][math.random(1,#dialogue[role][key])] or nil
end

local diaId = 0
local function showLine(text)
	diaId += 1
	local thisId = diaId
	
	
	dialoguelabel.Visible = true
	dialoguelabel.TextLabel.Text = ""
	typewrite(dialoguelabel.TextLabel, text, 0.02)

	task.delay(4, function()
		if thisId ~= diaId then return end
		dialoguelabel.Visible = false
	end)
end

local function newDia(eventKey)
	if not role or not personality then return end

	local roleTable = dialogue[role]
	if not roleTable then warn("newdia: role error : " ..role) return end

	local personalityTable = roleTable[personality]
	if not personalityTable then warn("newdia: personality error : " ..personality) return end

	local lines = personalityTable[eventKey]
	if not lines or #lines == 0 then warn("newdia: line error: " ..eventKey) return end

	local chosen = lines[math.random(1,#lines)]
	showLine(chosen)
end

local oDiaIds = {}
local function newOverhead(speaker, key, text:string?)
	print(speaker,key)
	local char = speaker.Character
	if not char then return end
	print(char)
	local head = char:FindFirstChild("Head")
	if not head then return end
	print(head)
	oDiaIds[speaker] = (oDiaIds[speaker] or 0) + 1
	local thisId = oDiaIds[speaker]
	
	for _,v in pairs(head:GetChildren()) do
		if v:IsA("BillboardGui") then
			v:Destroy()
		end
	end
	
	if key == "custom" then
		if not text then return end
		local bill = Instance.new("BillboardGui")
		bill.Adornee = head
		bill.MaxDistance = 50
		bill.Size = UDim2.new(20,0,0.7,0)
		bill.SizeOffset = Vector2.new(0,2)

		local label = Instance.new("TextLabel",bill)
		label.BackgroundTransparency = 1
		label.FontFace = Font.new("rbxasset://fonts/families/Inconsolata.json",Enum.FontWeight.Regular,Enum.FontStyle.Normal)
		label.Size = UDim2.new(1,0,1,0)
		label.TextColor3 = Color3.new(1,1,1)
		label.TextScaled = true
		label.TextWrapped = true

		local stroke = Instance.new("UIStroke",label)
		stroke.Color = Color3.new(1,0,0.016)
		stroke.LineJoinMode = Enum.LineJoinMode.Bevel
		stroke.Thickness = 0.001

		bill.Parent = head
		warn("custom line probably bc they chatted lol", bill:GetFullName(), head:GetFullName(), role, personality, text, speaker)
		typewrite(label, text, 0.02, script.noise, head)

		task.delay(4.5, function()
			if oDiaIds[speaker] ~= thisId then return end
			if bill then bill:Destroy() end
		end)
		
		return
	end

	local role = plrRoles[speaker]
	local personality = plrPersonalities[speaker]

	if not role or not personality then return end

	local lines = dialogue[role][personality][key]
	if not lines or #lines == 0 then return end

	local text = lines[math.random(1,#lines)]
	
	local bill = Instance.new("BillboardGui")
	bill.Adornee = head
	bill.MaxDistance = 50
	bill.Size = UDim2.new(20,0,0.7,0)
	bill.SizeOffset = Vector2.new(0,2)

	local label = Instance.new("TextLabel",bill)
	label.BackgroundTransparency = 1
	label.FontFace = Font.new("rbxasset://fonts/families/Inconsolata.json",Enum.FontWeight.Regular,Enum.FontStyle.Normal)
	label.Size = UDim2.new(1,0,1,0)
	label.TextColor3 = Color3.new(1,1,1)
	label.TextScaled = true
	label.TextWrapped = true

	local stroke = Instance.new("UIStroke",label)
	stroke.Color = Color3.new(1,0,0.016)
	stroke.LineJoinMode = Enum.LineJoinMode.Bevel
	stroke.Thickness = 0.001

	bill.Parent = head
	warn(bill:GetFullName(), head:GetFullName(), role, personality, text, speaker)
	typewrite(label, text, 0.02, script.noise, head)

	task.delay(4.5, function()
		if oDiaIds[speaker] ~= thisId then return end
		if bill then bill:Destroy() end
	end)
end

--// spectate stuff
local spectateUi = ui:WaitForChild("spectate")
local spectating = false
local spectateIndex = 1
local spectateList = {}

local function getTargets()
	local targets = {}

	for _, p in next, game:GetService("Players"):GetPlayers() do
		if p ~= plr and p:GetAttribute("Playing") then
			if p.Character and p.Character:FindFirstChildOfClass("Humanoid") then
				local hum = p.Character:FindFirstChildOfClass("Humanoid")
				if hum.Health > 0 then
					table.insert(targets, p)
				end
			end
		end
	end

	return targets
end

local function spectate(target)
	if not target or not target.Character then return end

	local hum = target.Character:FindFirstChildOfClass("Humanoid")
	if not hum then return end

	local cam = workspace.CurrentCamera
	cam.CameraType = Enum.CameraType.Custom
	cam.CameraSubject = hum

	spectateUi.name.Text = target.Name
end

local function startSpectating()
	plr.CameraMinZoomDistance = 0.5
	plr.CameraMaxZoomDistance = 10
	spectating = true
	spectateUi.Visible = true

	spectateList = getTargets()

	if #spectateList == 0 then
		spectateUi.name.Text = "No players alive"
		return
	end

	spectateIndex = 1
	spectate(spectateList[spectateIndex])
end

local function stopSpectating()
	if not spectating then return end
	plr.CameraMinZoomDistance = 0.5
	plr.CameraMaxZoomDistance = 0.5

	spectating = false
	spectateUi.Visible = false
	spectateList = {}
	spectateIndex = 1

	local cam = workspace.CurrentCamera
	cam.CameraType = Enum.CameraType.Custom

	if plr.Character then
		local hum = plr.Character:FindFirstChildOfClass("Humanoid")
		if hum then
			cam.CameraSubject = hum
		end
	end
end

spectateUi.next.MouseButton1Click:Connect(function()
	if not spectating then return end

	spectateList = getTargets()
	if #spectateList == 0 then return end

	spectateIndex += 1
	if spectateIndex > #spectateList then
		spectateIndex = 1
	end

	spectate(spectateList[spectateIndex])
end)

spectateUi.back.MouseButton1Click:Connect(function()
	if not spectating then return end

	spectateList = getTargets()
	if #spectateList == 0 then return end

	spectateIndex -= 1
	if spectateIndex < 1 then
		spectateIndex = #spectateList
	end

	spectate(spectateList[spectateIndex])
end)

task.spawn(function()
	while task.wait(1) do
		if spectating then
			local current = spectateList[spectateIndex]

			if not current or not current.Character or not current.Character:FindFirstChildOfClass("Humanoid") or current.Character:FindFirstChildOfClass("Humanoid").Health <= 0 then

				spectateList = getTargets()

				if #spectateList > 0 then
					spectateIndex = math.clamp(spectateIndex, 1, #spectateList)
					spectate(spectateList[spectateIndex])
				else
					spectateUi.name.Text = "No players alive"
				end
			end
		end
	end
end)

--//                  connections
remote.ClientSpectateCall.Event:Connect(function(act:string)
	if act == "start" then
		startSpectating()
	elseif act == "stop" then
		stopSpectating()
	end
end)

remote.VisualCall.OnClientEvent:Connect(function(key:string,...)
	local keyF = {
		setPersonality = function(tg, r, p)
			plrRoles[tg] = r
			plrPersonalities[tg] = p

			if plr == tg then
				role = r
				personality = p
			end
		end,

		dialogue = function(key,text:string?)
			if key == "custom" and text then
				showLine(text)
				return
			end
			newDia(key)
		end,

		playerSpoke = function(speaker, key, text:string?)
			if speaker.Name == plr.Name then warn("i said this doh") return end
			newOverhead(speaker,key, text)
		end,

		fadeOut = function()
			local roleframe = ui:FindFirstChild("role")
			tweenService:Create(roleframe,TweenInfo.new(0.75),{BackgroundTransparency = 0}):Play()
		end,

		roundPrepare = function()
			if not plr:GetAttribute("Playing") then
				local roleframe = ui:FindFirstChild("role")
				tweenService:Create(roleframe,TweenInfo.new(0.75),{BackgroundTransparency = 1}):Play()
				return
			end
			local roleframe = ui:FindFirstChild("role")
			roleframe.Visible = true
			for _,v in next,roleframe:GetDescendants() do
				if v:IsA("UIStroke") then
					v.Transparency = 0
				elseif v:IsA("TextLabel") then
					v.Text = ""
					v.TextTransparency = 0
				end
			end
			task.spawn(function()
				roleframe.b.TextColor3 = rolestrokecolors[role].stroke
				roleframe.b.shadow.TextColor3 = rolestrokecolors[role].main
				roleframe.BackgroundTransparency = 0
				task.wait(7)
				tweenService:Create(roleframe,TweenInfo.new(5,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut),{BackgroundTransparency = 1}):Play()
			end)
			newDia("start")
			task.wait(4.5)
			--// introduction screen
			typewrite(roleframe.a,role == "survivor" and "You are a" or "You are the",0.02)
			task.wait(1)
			task.spawn(function()
				typewrite(roleframe.b,string.upper(role),0.1)
			end)
			task.spawn(function()
				typewrite(roleframe.b.shadow,string.upper(role),0.1)
			end)
			task.wait(2.5)
			typewrite(roleframe.c,dialogue.roleDescriptions[role:lower()])
			--// introduction cleanup
			task.wait(3)
			for _,v in next,roleframe:GetDescendants() do
				if v:IsA("UIStroke") then
					tweenService:Create(v,TweenInfo.new(5,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut),{Transparency = 1}):Play()
				end
			end
			tweenService:Create(roleframe.a,TweenInfo.new(5,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut),{TextTransparency = 1}):Play()
			tweenService:Create(roleframe.b,TweenInfo.new(5,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut),{TextTransparency = 1}):Play()
			tweenService:Create(roleframe.b.shadow,TweenInfo.new(5,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut),{TextTransparency = 1}):Play()
			tweenService:Create(roleframe.c,TweenInfo.new(5,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut),{TextTransparency = 1}):Play()
		end,

		vig_killedInnocent = function()
			if not plr:GetAttribute("Playing") then return end
			showLine("...")
			task.wait(4)
			newDia("killedInnocent")
		end,

		timeRunningOut = function()
			if not plr:GetAttribute("Playing") then return end
			if role ~= "killer" then return end
			local s = Instance.new("Sound",plr.Character) s.Volume = 1.5 s.SoundId = "rbxassetid://121822774028821" s:Play()
			task.delay(s.TimeLength+3,pcall,game.Destroy,s)
			task.wait(2)
			newDia("timeRunningOut")
			--task.wait(4)
			--showLine("Increase time by killing. If you don't do it you won't last much longer.")
		end,

		roundEnd = function()
			if not plr:GetAttribute("Playing") then return end
			task.wait()
			showLine("")
		end,

		roundEndDia = function()
			if not plr:GetAttribute("Playing") then return end
			local status = gamestatus.Status
			if status.Value == "killerDead" and role ~= "killer" then
				newDia("end_killerdead")
			elseif status.Value == "killerDeadSelf" and role ~= "killer" then
				newDia("end_timeover")
			elseif status.Value == "timeOver" and role ~= "killer" then
				newDia("end_timeover")
			elseif status.Value == "killerWins" and role ~= "vigilante" and role ~= "survivor" then
				newDia("end_killerwins") 
			end
		end,
		
		reset = function()
			if spectating then stopSpectating() end
			
		end,
	}

	if not keyF or not keyF[key] then return end
	keyF[key](...)
end)]]></ProtectedString>
						<bool name="Disabled">false</bool>
						<Content name="LinkedSource"><null></null></Content>
						<token name="RunContext">0</token>
						<string name="ScriptGuid">{614F1E5B-2DFD-40EB-8E81-017A9A49FBED}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<string name="Name">UiHandler</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
					</Properties>
					<Item class="ModuleScript" referent="RBX2AB0DBE56DE044E384ED0FC7035A0116">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local dia = {
	survivor = {
		rational = {
			start = {
				"A place like this means structure... Structure means patterns...",
				"I need to find a pattern... a way out...",
				"Don't worry... just stay calm.. you'll be okay."
			},
			end_killerdead = {
				"There's no more threat... right?",
				"I think I'm safe now... I can rest..."
			},
			end_timeover = {
				"Okay... I think it's gone...",
				"It's over... I think..."
			},
			shotByVig =  {
				"Wait- this doesn't make sense!",
				"Hold on! I'm not your enemy!",
				"Stop!! You're making a mistake!"
			},
