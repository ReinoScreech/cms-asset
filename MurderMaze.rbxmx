							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local Services = setmetatable({}, {
	__index = function(self, key)
		local s = game:GetService(key)
		rawset(self, key, s)
		return s
	end
}) :: typeof(game)

return {
	maze = function()
		Services.SoundService.AmbientReverb = Enum.ReverbType.Alley
		if not Services.Lighting:FindFirstChildOfClass("Sky") then
			local nightSky = Instance.new("Sky")
			nightSky.Name = "NightSky"
			nightSky.SunAngularSize = 0
			nightSky.Parent = Services.Lighting
		end
		local ambience = Instance.new("Sound",workspace)
		ambience.SoundId = "rbxassetid://6189441072"
		ambience.Looped = true
		local ambience2 = Instance.new("Sound",workspace)
		ambience.SoundId = "rbxassetid://8935604268"
		ambience2.Volume = 0.2
		ambience2.Looped = true
		ambience:Play()
		ambience2:Play()

		local val = {
			ClockTime = 0,
			Brightness = 0.05,
			ExposureCompensation = -1,
			Ambient = Color3.fromRGB(10, 10, 20),
			OutdoorAmbient = Color3.fromRGB(15, 15, 30),
			GlobalShadows = true
		}

		for prop, val in next, val do
			if Services.Lighting[prop] ~= val then
				Services.Lighting[prop] = val
			end
		end
		
		for _,v in next, Services.Players:GetPlayers() do
			pcall(function()
				local f = script.Parent.Parent.Flashlight:Clone()
				f.Parent = v.Backpack
			end)
		end
	end,
}]]></ProtectedString>
