										<ProtectedString name="Source"><![CDATA[--!strict
--// Written jun. 7. 2025
--// Rewritten jul. 15. 2025
--// This was ported from one of my testing games so it might be messy in here

local runService = game:GetService("RunService")
local replicatedStorage = game:GetService("ReplicatedStorage")
local players = game:GetService("Players")
local debris = game:GetService("Debris")

local c = script.Parent
repeat wait() until (c:FindFirstChild("HumanoidRootPart") or c:FindFirstChild("Torso")) or wait(2)
root = assert(c:FindFirstChild("HumanoidRootPart") or c:FindFirstChild("Torso"), `ROOT ERROR! The root for {c} was not found!`)

--local plrSounds = p:WaitForChild("PlayerGui"):WaitForChild("Storage"):FindFirstChild("MaterialSounds_L") --// MatLoader initializes this on PlayerAdded
local mainSounds = script:FindFirstChild("MaterialSounds_M")

local matSounds = mainSounds
if not matSounds then error("! Both the local impact folder and master folder were not found! Check your directories and restart your game when ready.") end

local allowed = true --c:WaitForChild("Impact")
local lastTime = 0
local lastWallTime = 0
local lastimpactwashard = true
local cooldown = 0.1

local limbs = {}
local materialAliases = {
	SmoothPlastic = "Plastic",
	Neon = "Plastic",
	CorrodedMetal = "Metal",
	DiamondPlate = "Metal",
	Foil = "Plastic",
	Granite = "Concrete",
	Brick = "Concrete",
	Pebble = "Concrete",
	Asphalt = "Concrete",
	Sandstone = "Sand",
	Slate = "Concrete",
	Concrete = "Concrete",
	Plastic = "Plastic",
	WoodPlanks = "Wood",
	Wood = "Wood",
	Snow = "Grass",
	Grass = "Grass",
	Sand = "Grass",
	Mud = "Grass",
	LeafyGrass = "Grass",
	Ground = "Grass",
	Fabric = "Carpet",
}
local cachedVelos = {}

local slideFolder = matSounds:WaitForChild("Sliding")
local slideThreshold = 10
local verticalThreshold = 2
local slideTag = "_slideTag"

local lastSend = 0
local sendDelay = 1.5

local nocheckparts = {"ayybleed"}
for _,part in ipairs(c:GetChildren()) do
	if part:IsA("BasePart") and not table.find(nocheckparts,part.Name:lower()) then
		table.insert(limbs, part)
	end
end

--// Return intensity of an impact based on speed
local function getIntensity(verticalSpeed, horizontalSpeed, isWall)
	--warn(verticalSpeed, horizontalSpeed, isWall)
	if isWall and horizontalSpeed > 180 then
		return math.clamp(horizontalSpeed / 120, 1, 4)
	elseif not isWall and verticalSpeed > 180 then
		return math.clamp(verticalSpeed / 120, 1, 4)
	end
	return nil
end

--// Play an impact sound given a material, limb, and position
local function playSound(material, impactType, limb, pos, fireEvent, intensity)
	--print("A sound will play.")
	local folder = matSounds:FindFirstChild(impactType)
	if not folder then return end
	local soundGroup = folder:FindFirstChild(material) or folder:FindFirstChild("Default")
	if not soundGroup or #soundGroup:GetChildren() == 0 then return end

	local soundTemplate = soundGroup:GetChildren()[math.random(1, #soundGroup:GetChildren())]
	local sound = soundTemplate:Clone()
	if not intensity then sound.PlaybackSpeed = math.random(90, 120) / 100 end
	sound.RollOffMode = Enum.RollOffMode.InverseTapered
	sound.RollOffMaxDistance = 250
	if not intensity then sound.Volume = (impactType == "Soft") and 0.4 or 1 end

	if intensity then
		--print("ps", intensity)
		sound.Volume = math.clamp(0.75 * intensity, 1, 3)
		sound.PlaybackSpeed = math.clamp(1 - 0.15 * (intensity - 1), 0.5, 0.9)
		--print(sound.Volume, sound.PlaybackSpeed, "Real:", 0.4 * intensity, 1 - 0.15 * (intensity - 1), "Int:", intensity)
	end	
	--print("The sound data", sound, sound.Volume, sound.PlaybackSpeed, sound.SoundId)
	sound.Parent = limb
	sound:Play()
	debris:AddItem(sound, 3.5)

	if fireEvent then

	end
end

--// Create a dust effect at the given position
local function dust(impactType, pos, material, instance, intensity)
	if impactType ~= "Hard" then return end
	local dust = script:FindFirstChild("Dust")
	if dust then
		local dustColors = {
			Grass = ColorSequence.new(Color3.fromRGB(86, 66, 54)),
			Wood = ColorSequence.new(Color3.fromRGB(191, 147, 92)),
			Carpet = instance and ColorSequence.new(instance.Color) or nil
		}
		local effect = dust:Clone()
		effect.Position = pos
		effect.Transparency = 1
		effect.CanCollide = false
		effect.Anchored = true
		effect.Parent = workspace

		if not effect:FindFirstChild("Effect") then return end
		if dustColors[material] then effect.Effect.Color = dustColors[material] end
		if intensity then
			local scale = intensity or 1
			--print(intensity,scale,15 * scale,0.65 + scale * 0.15,0.8 + scale * 0.2)
			effect.Effect.Size = NumberSequence.new({
				NumberSequenceKeypoint.new(0, 0.75 * scale),
				NumberSequenceKeypoint.new(1, 2.38 * scale)
			})
			effect.Effect.Lifetime = NumberRange.new(0.65 + scale * 0.15, 0.8 + scale * 0.2)
			
			task.spawn(function()
				task.wait(.02)
				effect.Effect:Emit(math.clamp(15 * scale, 15, 60))
			end)
			debris:AddItem(effect, 2 + scale * 0.25)
		else
			task.spawn(function()
				task.wait(.02)
				effect.Effect:Emit(math.random(15, 30))
			end)
			debris:AddItem(effect, 2)
		end
	end
end

--// Visualize raycasts for debugging
local function debugRaycast(impactType, pos, wallcheck)
	return
		--[[
	local box = Instance.new("Part", workspace)
	box.Name = "RayHitDot"
	box.Material = Enum.Material.SmoothPlastic
	box.Shape = Enum.PartType.Ball
	box.Size = Vector3.new(1.5,1.5,1.5)
	box.Color = (impactType == "Hard") and Color3.new(1, 0, 0) or Color3.new(0, 1, 0)
	box.Anchored = true
	box.CanCollide = false
	box.Position = pos
	debris:AddItem(box, 5)
	]]
end

--// Check if limb collided with wall and replace the main raycast if true
local function wallCheck(limb, velocity)
	if lastimpactwashard and tick() - lastWallTime < cooldown then return end
	local horizontalSpeed = (velocity * Vector3.new(1, 0, 1)).Magnitude
	local verticalSpeed = math.abs(-velocity:Dot(Vector3.yAxis))
	if horizontalSpeed < 12 then return false end 

	local direction = velocity.Unit
	local rayLength = 3.5
	local origin = limb.Position
	local rayDirection = direction * rayLength

	local params = RaycastParams.new()
	params.FilterDescendantsInstances = {c}
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.IgnoreWater = true

	local ray = workspace:Raycast(origin, rayDirection, params)

	if ray and ray.Instance and not ray.Instance:IsDescendantOf(c) then
		local normal = ray.Normal
		local upwardDot = normal:Dot(Vector3.yAxis)

		if upwardDot > 0.5 then return end
		if not ray.Instance.CanCollide then return end

		local material = materialAliases[ray.Material.Name] or ray.Material.Name
		local impactType = (horizontalSpeed >= 45 or verticalSpeed >= 65) and "Hard" or "Soft"
		local rawMaterial = ray.Instance:GetAttribute("IntMaterial") or ray.Material.Name
		material = materialAliases[rawMaterial] or rawMaterial
		local intensity = getIntensity(verticalSpeed, horizontalSpeed, true)

		debugRaycast(impactType, ray.Position, true)
		playSound(material, impactType, limb, ray.Position, true, intensity)
		dust(impactType, ray.Position, material, ray.Instance, intensity)

		lastWallTime = tick()
		return true
	end
end

--// Check if player is sliding and prevent impact sounds during it
local function slideCheck(vel, ray)
	if not ray then return false end

	local verticalSpeed = math.abs(-vel:Dot(Vector3.yAxis))
	local horizontalSpeed = (vel * Vector3.new(1, 0, 1)).Magnitude

	local normal = ray.Normal
	local normalDot = normal:Dot(Vector3.yAxis)

	local slopeDirection = Vector3.new(normal.X, 0, normal.Z)
	if slopeDirection.Magnitude > 0.001 then
		slopeDirection = -slopeDirection.Unit
	else
		slopeDirection = Vector3.zero
	end



	local isSlope = normalDot > 0.35 and normalDot < 0.9 
	local projected = math.abs(vel:Dot(slopeDirection))

	local slidingDownSlope = isSlope and projected >= 10
	local slidingOnFlatGround = not isSlope and verticalSpeed < 6 and horizontalSpeed >= 10

	if slidingOnFlatGround or slidingDownSlope then
		return true
	end
	return false
end

runService.Heartbeat:Connect(function()
	if not c or not c:IsDescendantOf(workspace) then --[[warn("oops")]] return end
	if allowed ~= true then --// Redundant now because a client sided sliding sound would make no sense
		if root:FindFirstChild(slideTag) then
			root:FindFirstChild(slideTag):Stop()
			root:FindFirstChild(slideTag):Destroy()
		end
		return
	end

	local params = RaycastParams.new()
	params.FilterDescendantsInstances = {c}
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.IgnoreWater = true

	for _, limb in ipairs(limbs) do
		if limb:IsA("BasePart") then
			local vel = limb.AssemblyLinearVelocity

			local check = wallCheck(limb, vel)
			if lastimpactwashard and tick() - lastTime < cooldown then return end

			local verticalSpeed = math.abs(-vel:Dot(Vector3.yAxis))
			local horizontalSpeed = (vel * Vector3.new(1, 0, 1)).Magnitude
			if check then continue end
			local rayDirection = Vector3.new(0, -2.5, 0)
			local limbRay = workspace:Raycast(limb.Position, rayDirection, params)
			local rootRay = workspace:Raycast(root.Position, rayDirection, params)
			local angularSpeed = root.AssemblyAngularVelocity.Magnitude
			--// rootRay and angularSpeed are fallbacks
			
			local ray = limbRay or rootRay
			local isSliding = slideCheck(vel, ray)
			if ray then
				--slideCheck(limb, vel, ray)
				local rayname = "Ray"
				if limbRay then rayname = "limbRay" else rayname = "rootRay" end
				if ray.Instance.CanCollide == false then return end
				if (verticalSpeed >= 12 or horizontalSpeed >= 12) or angularSpeed >= 10 then


					if isSliding then continue end

					local material = materialAliases[ray.Material.Name] or ray.Material.Name --// Mainly a fallback, rawMaterial handles this
					local impactType = (verticalSpeed >= 65 or horizontalSpeed >= 45) and "Hard" or "Soft"
					--if impactType == "Hard" then lastimpactwashard = true else lastimpactwashard = false end
					local rawMaterial = ray.Instance:GetAttribute("IntMaterial") or ray.Material.Name
					material = materialAliases[rawMaterial] or rawMaterial
					--// ^ Utilizes the internal material name if attributed. Uses material property otherwise
					--print(limb,verticalSpeed, horizontalSpeed)
					local intensity = getIntensity(verticalSpeed, horizontalSpeed, false)

					--if isSliding then continue end
					debugRaycast(impactType, ray.Position, false)
					playSound(material, impactType, limb, ray.Position, true, intensity) --// Use ray.Position and true for parameters 4 and 5 to fire sound on server
					dust(impactType, ray.Position, material, ray.Instance, intensity)

					lastTime = tick()
					break
				end
			end
		end
	end
end)

local rCache = {}
local cd = 0.25
local threshold = 4]]></ProtectedString>
