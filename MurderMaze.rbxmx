					<Item class="ModuleScript" referent="RBX2112E3D5F47243DA82EF005AD48241BF">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[--!native
local Services = setmetatable({}, {
	__index = function(self, key)
		local s = game:GetService(key)
		rawset(self, key, s)
		return s
	end
}) :: typeof(game)

local module = { --// Revision 18 04.02.26 (MDY) 
	--// Merry springmas to you all
	
	run = function(settings)
		local plrs = game:GetService("Players")
	
		local addons:{} = settings and settings.Addons
		local runonserver:boolean = settings and settings.RunOnServer
		local notorsocollide:boolean = settings and settings.NoCollisions or false
		local reload:boolean = settings and settings.Reload
		local ragtype:string = settings and tostring(settings.Type)
		local dt:number = settings and tonumber(settings.DespawnTime) or 25
		local movable:boolean = settings and settings.Movable or false
		local loadall:boolean = settings and settings.LoadAll or false
		
		if runonserver == nil then
			runonserver = true
		end
		if reload == nil then
			reload = true
		end
		
		
		print(`rev.{script:GetAttribute("Revision") or "unknown"}`)
		
		if reload then
			local rep, schr, sss = game:GetService("ReplicatedStorage"),game:GetService("StarterPlayer"):WaitForChild("StarterCharacterScripts"), game:GetService("ServerScriptService")
			for _,v in pairs(rep:GetChildren()) do
				if v.Name == "PlatformStandCollisions" or v.Name == "DefaultCharacter" then
					v:Destroy()
				end
			end
			
			for _,v in pairs(schr:GetChildren()) do
				if v.Name == "RagdollScript" then
					v:Destroy()
				end
			end
			
			for _,v in pairs(sss:GetChildren()) do
				if v.Name == "RagdollScript" then
					v:Destroy()
				end
			end
			task.wait()
		end
		if not runonserver then
			warn("NewRagdoll: To use new enhancements please enable RunOnServer in the settings argument .run({RunOnServer = true})")
		end
		if Services.ReplicatedStorage:FindFirstChild("PlatformStandCollisions") or Services.StarterPlayer:FindFirstChildOfClass("StarterCharacterScripts"):FindFirstChild("RagdollScript") then return end 
		local r = script:WaitForChild("RagdollScript"):Clone()
		local f = r.Functions
		
		if ragtype ~= "" and ragtype ~= nil then
			f:SetAttribute("RagdollType",settings.Type)
		end
		if notorsocollide then
			f:SetAttribute("NoCollisions",settings.NoCollisions)
		end
		
		if addons then
			local fol = Instance.new("Folder")
			fol.Name = "Addons"
			fol.Parent = r
			
			for _,v in pairs(settings.Addons) do
				local obj = f:FindFirstChild(v)
				if obj == nil then continue end
				local d = Instance.new("ObjectValue")
				d.Name = v
				d.Value = obj
				d.Parent = fol
			end
		end
		r.DelayValue.Value = dt
		r.Movable.Value = movable
		
		r.Movable.Parent = f
		r.DelayValue.Parent = f
		r.Camera.Parent = f
		
		if runonserver then
			r.Parent = game:GetService("ServerScriptService")
		else
			r.Parent = game:GetService("StarterPlayer"):FindFirstChildOfClass("StarterCharacterScripts")
		end
		
		r.Enabled = true
		local p = script:WaitForChild("PlatformStandCollisions"):Clone()
		p.Parent = game:GetService("ReplicatedStorage")
		local c = script:WaitForChild("DefaultCharacter"):Clone()
		c.Parent = game:GetService("ReplicatedStorage")
		
		if loadall then
			for _,v in pairs(plrs:GetPlayers()) do
				v:LoadCharacter()
			end
		end
	end,
}

return module
]]></ProtectedString>
							<string name="ScriptGuid">{FAA236F1-47D4-4F0B-9437-57A525DA0CB0}</string>
							<BinaryString name="AttributesSerialize">AQAAAAgAAABSZXZpc2lvbgILAAAAMTgtMDQuMDIuMjY=</BinaryString>
							<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
							<bool name="DefinesCapabilities">false</bool>
							<string name="Name">newrag</string>
							<int64 name="SourceAssetId">72475888993201</int64>
							<BinaryString name="Tags"></BinaryString>
						</Properties>
						<Item class="Script" referent="RBX19BE31B566BA405A9640FC136575B0E3">
							<Properties>
								<ProtectedString name="Source"><![CDATA[local f = require(script.Functions)
listeningmodels = {}
local plrs = game:GetService("Players")
if script:IsDescendantOf(game:GetService("ServerScriptService")) then
	local function onPlayerAdded(plr:Player)

		local function onChrAdded(chr:Model)
			if not chr then return end
			local humanoid = chr:FindFirstChild("Humanoid")
			--print(chr,humanoid)
			if humanoid then
				local a = humanoid.Died:Connect(function() f.ondeath(chr) end)

				chr.DescendantRemoving:Connect(function(d)
					if d:IsA("Humanoid") then
						--print("humanoid removed", d)
						humanoid = nil
						a:Disconnect()
					end
				end)
				chr.DescendantAdded:Connect(function(d)
					if d:IsA("Humanoid") --[[and not chr:FindFirstChild("Humanoid")]] then
						--print("humanoid added", d.Parent)
						humanoid = d
						a = humanoid.Died:Connect(function() f.ondeath(chr) end)
					end
				end)
			end
		end

		onChrAdded(plr.Character)
		plr.CharacterAdded:Connect(onChrAdded)
	end

	for _,v in plrs:GetPlayers() do
		onPlayerAdded(v)
	end
	plrs.PlayerAdded:Connect(onPlayerAdded)

	workspace.DescendantAdded:Connect(function(d)
		if d:IsA("Model") then
			task.wait(0.5)
			--print("npc call")
			if d:FindFirstChildOfClass("Humanoid") --[[and table.find({"Head", "Torso", "UpperTorso", "LowerTorso"}, d:GetDescendants())]] then
				--print("humanoid found")
				if d:FindFirstChildOfClass("DragDetector") then return end
				local hum = d:FindFirstChildOfClass("Humanoid")
				local p = plrs:GetPlayerFromCharacter(d.Parent)
				if hum.Health <= 0.5 or plrs:GetPlayerFromCharacter(hum.Parent) then return --[[print("likely not an intended npc or is a player")]] end
				local c = hum.Parent
				--print(hum,c)
				table.insert(listeningmodels, c)

				local listener = hum.Died:Connect(function() f.ondeath(c) end)
				task.spawn(function()
					while task.wait() do
						if c == nil or hum == nil then
							listener:Disconnect()
							table.remove(listeningmodels, table.find(listeningmodels,c))
							break
						end						
					end
				end)

			end
		end
	end)
else
	script.Parent:FindFirstChildOfClass("Humanoid").Died:Connect(function()
		f.ondeath(script.Parent)
	end)
end]]></ProtectedString>
