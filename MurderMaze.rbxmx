Tool.Equipped:Connect(function()
	plr=Services.Players:GetPlayerFromCharacter(Tool.Parent)

	Character = plr.Character
	Humanoid = Character:WaitForChild("Humanoid")
	RootpartThing = plr.Character:WaitForChild("HumanoidRootPart")
