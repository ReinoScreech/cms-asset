		TweenAnimate(FunnyRH,{C0 = CFrame.new(1,-1,0)*CFrame.Angles(math.rad(-5),math.rad(0),math.rad(5))*CFrame.Angles(math.rad(0),math.rad(90),math.rad(0))},.15,"Sine","Out",0,false,0)	

