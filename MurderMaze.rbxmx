		TweenAnimate(FunnyLW,{C0=cf(-1.5,-.1+.1*math.cos(Sine/25),-0.3)*angles(math.rad(114.2-2*math.sin(Sine/25)),math.rad(-13.9),math.rad(30.5))*LeftShoulderC0},.35,"Back","InOut",0,false,0)	
