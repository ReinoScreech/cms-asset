										<BinaryString name="AttributesSerialize"></BinaryString>
										<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
										<bool name="DefinesCapabilities">false</bool>
										<string name="Name">Denyers</string>
										<int64 name="SourceAssetId">-1</int64>
										<BinaryString name="Tags"></BinaryString>
									</Properties>
								</Item>
								<Item class="ModuleScript" referent="RBX14BCA592561F4D688B3FEC5E33981EB3">
									<Properties>
										<Content name="LinkedSource"><null></null></Content>
										<ProtectedString name="Source"><![CDATA[return (function(char)
		if not script:FindFirstChild("Sounds") then return nil end
		local sound = script.Sounds:GetChildren()[math.random(1,#script.Sounds:GetChildren())]
		if sound == nil then return end
		sound = sound:Clone()
		sound.Name = "DeathNoise"
		sound.Volume = 1
		sound.Pitch = math.random(100,125) / 100
		sound.Parent = char:FindFirstChild("Head",true)
		sound:Play()
end)]]></ProtectedString>
