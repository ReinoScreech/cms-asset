function InstanceNW(typp,anth)
	local part = Instance.new(typp)
	if anth ~= nil then for i,v in next, anth do pcall(function() part[i] = v end) end end
	return part


end

function Kill(who,power,notorso,headless,full)
	coroutine.resume(coroutine.create(function()
		if who.Parent ~= MainModel and who.Parent ~= EffectModel and who ~= MainModel and who ~= EffectModel and who ~= cam and who.Parent ~= cam and who ~= script and who.Parent ~= script and who:FindFirstChild("KilledBy"..plr.Name) == nil and who.Name ~= plr.Name then
			InstanceNW("Folder",{Parent=who,Name="KilledBy"..plr.Name})
			local mainpart = (who:FindFirstChildOfClass'Part' or who:FindFirstChildOfClass'MeshPart' or who:FindFirstChildOfClass'UnionOperation') CreateSound(mainpart,7122613461,.6,1,{MaxDistance = 300}) CreateSound(mainpart,4617835866,.6,1,{MaxDistance = 300}) CreateSound(mainpart,Skullsounds[math.random(1,#Skullsounds)],.6,1,{MaxDistance = 300})
			for _,a in pairs(who:GetChildren()) do
				coroutine.resume(coroutine.create(function()
					if a:IsA'BasePart' then
						local pos = a.CFrame*CFrame.new(math.random(-a.Size.X,a.Size.X)/2,math.random(-a.Size.Y,a.Size.Y)/2,math.random(-a.Size.Z,a.Size.Z)/2)
						if math.random(1,2)==1 then
							for i=1,math.random(3,6) do
								add:BloodDrop(a.CFrame,Vector3.new(math.random(-10,10),math.random(50,125),math.random(-10,10)),math.random(45,55)/100,3,{MainModel,cam,who},EffectModel)
							end
						end
						coroutine.resume(coroutine.create(function()
							plr.Character.Humanoid.MaxHealth = plr.Character.Humanoid.MaxHealth + 5
							plr.Character.Humanoid.Health = plr.Character.Humanoid.Health + 5

						end))


						local blood=BloodBackup:Clone() blood.Parent=a blood.Enabled=true local mist=MistBackup:Clone() mist.Parent=a mist.Enabled=true wait(0.2) blood.Enabled=false mist.Enabled=false wait(2) blood:Destroy() mist:Destroy() 
					end
				end))
			end
			add:MakeRD(who,power,notorso,headless,full,false)
			spawn(function()
				while who ~= nil do swait()
					if who:FindFirstChildOfClass("Humanoid") ~= nil then who:FindFirstChildOfClass("Humanoid").MaxHealth=nil who:FindFirstChildOfClass("Humanoid").Health=nil end
				end
			end)
		end
	end))
end

function Damage(Table)
	for _,v in pairs(workspace:GetDescendants()) do
		if v:FindFirstChild("Torso") and v:FindFirstChildOfClass("Humanoid") --[[and v:FindFirstChildOfClass("Humanoid").Health >= 0]] and v ~= plr.Character then
			local Damage = math.random(Table.MinDamage,Table.MaxDamage)
			local pc = script.Addons:WaitForChild("HitFF1"):Clone()
			local pc2 = script.Addons:WaitForChild("HitFF2"):Clone()
			local Victim = v
			local Torso = Victim["Torso"]
			local Humanoid = Victim:FindFirstChildOfClass("Humanoid")
			if (Torso.Position - Table.Position.Position).Magnitude <= Table.Magnitude then
				Humanoid:TakeDamage(Damage)
				pcall(function()
					local playerVictim = game:GetService("Players"):GetPlayerFromCharacter(Victim)
					local remote = game:GetService("ReplicatedStorage"):WaitForChild("Shared").Remote
					local gamestatus = game:GetService("ReplicatedStorage"):WaitForChild("Shared").GameStatus
					if playerVictim then
						if Humanoid.Health > 0 then
							remote.VisualCall:FireClient(playerVictim, "dialogue", "hurtByKiller")
							remote.VisualCall:FireAllClients("playerSpoke", playerVictim, "hurtByKiller")
						else
							gamestatus.Time.Value += math.random(200,450)/10
							--gamestatus.Time.Value = tonumber(tostring(string.format("%.2f", gamestatus.Time.Value + (math.random(200,450)/10))))
							remote.VisualCall:FireClient(plr, "dialogue", "killedPlayer")
						end
					end
				end)
				-------------Weird Blood Function--------
				if Table.Blood == true then
					pc.Parent = Torso pc:Emit(50)
					pc2.Parent = Torso pc2:Emit(50)
					Services.Debris:AddItem(pc,3) Services.Debris:AddItem(pc2,3)
					if math.random(1,2) then
						for i=1,math.random(1,3) do
							add:BloodDrop(Torso.CFrame,Vector3.new(math.random(-10,10),math.random(25,25),math.random(-10,10)),math.random(45,55)/100,3,{MainModel,cam,Victim},EffectModel)
						end end Bloodi()
					if Humanoid.Health <= 1 then
						Kill(Victim,3,false,true,false)
					end
				elseif Table.Blood == false then
					if Humanoid.Health <= 1 then
						coroutine.resume(coroutine.create(function()
							add:MakeRD(Victim,3,false,false,false,false)
						end))
					end	
				end 
				if Table.Sound then
					if Table.Blood == true then
						CreateSound(Torso,Fleshsounds[math.random(1,#Fleshsounds)],.5,1,{MaxDistance = 300})
					elseif Table.Blood == false then
						CreateSound(Torso,Table.Sound,2,math.random(10,15)/10,{MaxDistance = 300})
					end
				end
				-------------Weird Blood Function--------
				if Table.Type and Victim.PrimaryPart then

					if Table.Type == "Push" then
						Victim:SetPrimaryPartCFrame(Victim.PrimaryPart.CFrame*CFrame.Angles(math.rad(90),0,0))

						coroutine.resume(coroutine.create(function()
							Humanoid.PlatformStand = true
							wait(5)
							Humanoid.PlatformStand = false
						end))
						local vel = Instance.new("BodyVelocity",Victim.Torso) 
						vel.P =  6000 
						vel.MaxForce = Vector3.new(4000000,4000000,4000000)
						vel.Velocity = plr.Character.HumanoidRootPart.CFrame.lookVector * 75
						Services.Debris:AddItem(vel,.1)
					elseif 	Table.Type == "PushHand" then
						Victim:SetPrimaryPartCFrame(Victim.PrimaryPart.CFrame*CFrame.new(math.rad(math.random(-2,2)),0,math.rad(math.random(-15,15)))*CFrame.Angles(math.rad(math.random(-2,2)),math.rad(math.random(-2,2)),math.rad(math.random(-2,2))))

						coroutine.resume(coroutine.create(function()
							Humanoid.PlatformStand = true
							wait(2.5)
							Humanoid.PlatformStand = false
						end))
						local vel = Instance.new("BodyVelocity",Victim.Torso) 
						vel.P =  6000 
						vel.MaxForce = Vector3.new(4000000,4000000,4000000)
						vel.Velocity = plr.Character.HumanoidRootPart.CFrame.lookVector * 10
						Services.Debris:AddItem(vel,.1)

					end
				end
			end
		end
	end
end


function Bloodi(Table)
	dirtyohnoo = true
	local juices = ToolModel.BloodiedBlade
	for i,v in pairs(juices:GetChildren()) do
		if v:IsA("Texture")  then
			v.Transparency=v.Transparency-0.15


		elseif v:IsA("ParticleEmitter")  then
			v.Enabled = true
		end
	end
end

