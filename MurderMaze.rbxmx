					<Item class="ModuleScript" referent="RBX12D1D668F9CB4C0F8DE90B82724088DA">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[--// Uses source from one of my games
local tag = {}

--// Tag a player's humanoid for combat
function tag.TagHumanoid(humanoid:Humanoid,tagger:Model,decay:number)
	for _,t in pairs(humanoid:GetDescendants()) do
		if (t:IsA("ObjectValue") and t.Name == "creator") then
			t:Destroy()
		end
	end
	
	local tag = Instance.new("ObjectValue")
	tag.Name = "creator"
	tag.Value = tagger
	tag.Parent = humanoid
	game:GetService("Debris"):AddItem(tag,decay or 10)
	warn("ontag:", tag,humanoid,tagger)
end

--// Check if a user is tagged or not
function tag.IsTagged(chr:Model)
	local found,tag
	local humanoid = chr:FindFirstChild("Humanoid")
	if not humanoid then return end
	for _,t in pairs(humanoid:GetDescendants()) do
		if t:IsA("ObjectValue") and t.Name == "creator" then
			found = true
			tag = t
			break
		end
	end
	warn("isfound:", found or false,humanoid,tag,chr)
	return found or false,tag
end

return tag
]]></ProtectedString>
							<string name="ScriptGuid">{2EBA89D7-FFC1-4965-8674-4817D40DE97D}</string>
