local Player = Services.Players.LocalPlayer
local Camera = workspace.CurrentCamera
local Mouse = Player:GetMouse()
local db = false
local numbeeee = 1
local HeadFollow=true
local Resetted=false
local triggerthing,running = false,false
local Walkspeedthingmongus = {}
local CamStatus
local a=IT("Sound")function CreateSound(f,c,e,d,b)local g=nil coroutine.resume(coroutine.create(function()g=a:Clone()g.Parent=c g.Volume=e g.Pitch=d g.SoundId="rbxassetid://"..f g:play()if b==true then g.Looped=true else repeat wait(1)until g.Playing==false g:remove()end end))return g end function Swait(a)if a==0 or a==nil then game:service'RunService'.Stepped:wait(0)else for a=0,a do game:service'RunService'.Stepped:wait(0)end end end function CreatePart(d,b,e,i,f,g,h,c,a)local j=IT("Part")j.formFactor=d j.Reflectance=i j.Transparency=f j.CanCollide=false j.Locked=true j.Anchored=true if a==false then j.Anchored=false end j.BrickColor=BRICKC(tostring(g))j.Name=h j.Size=c j.Position=Player.Character.HumanoidRootPart.Position j.Material=e j:BreakJoints()j.Parent=b return j end function CreateMesh(e,d,b,f,g,c,a)local h=IT(e)if e=="SpecialMesh"then h.MeshType=b if f~="nil"and f~=""then h.MeshId="http://www.roblox.com/asset/?id="..f end if g~="nil"and g~=""then h.TextureId="http://www.roblox.com/asset/?id="..g end end h.Offset=a or VT(0,0,0)h.Scale=c h.Parent=d return h end 
function WACKYEFFECT(h)local q=(h.EffectType or"Sphere")local r=(h.Size or VT(1,1,1))local a=(h.Size2 or VT(0,0,0))local k=(h.Transparency or 0)local b=(h.Transparency2 or 1)local n=(h.CFrame or Player.Character.HumanoidRootPart.CFrame)local p=(h.MoveToPos or nil)local e=(h.RotationX or 0)local c=(h.RotationY or 0)local f=(h.RotationZ or 0)local g=(h.Material or"Neon")local d=(h.Color or C3(1,1,1))local o=(h.Time or 45)local j=(h.SoundID or nil)local i=(h.SoundPitch or nil)local h=(h.SoundVolume or nil)coroutine.resume(coroutine.create(function()local l=false local m=nil local s=CreatePart(3,workspace,g,0,k,BRICKC("Pearl"),"Effect",VT(1,1,1),true)if j~=nil and i~=nil and h~=nil then l=true m=CreateSound(j,s,h,i,false)end s.Color=d local h=nil if q=="Sphere"then h=CreateMesh("SpecialMesh",s,"Sphere","","",r,VT(0,0,0))elseif q=="Block"or q=="Box"then h=IT("BlockMesh",s)h.Scale=r elseif q=="Wave"then h=CreateMesh("SpecialMesh",s,"FileMesh","20329976","",r,VT(0,0,-r.X/8))elseif q=="Ring"then h=CreateMesh("SpecialMesh",s,"FileMesh","559831844","",VT(r.X,r.X,0.1),VT(0,0,0))elseif q=="Slash"then h=CreateMesh("SpecialMesh",s,"FileMesh","662586858","",VT(r.X/10,0,r.X/10),VT(0,0,0))elseif q=="Round Slash"then h=CreateMesh("SpecialMesh",s,"FileMesh","662585058","",VT(r.X/10,0,r.X/10),VT(0,0,0))elseif q=="Swirl"then h=CreateMesh("SpecialMesh",s,"FileMesh","1051557","",r,VT(0,0,0))elseif q=="Skull"then h=CreateMesh("SpecialMesh",s,"FileMesh","4770583","",r,VT(0,0,0))elseif q=="Crystal"then h=CreateMesh("SpecialMesh",s,"FileMesh","9756362","",r,VT(0,0,0))elseif q=="Duck"then h=CreateMesh("SpecialMesh",s,"FileMesh","9419831","9419827",r,VT(0,0,0))end if h~=nil then local g=nil if p~=nil then g=(n.p-p).Magnitude/o end local d=r-a local b=k-b if q=="Block"then s.CFrame=n*ANGLES(RAD(MRANDOM(0,360)),RAD(MRANDOM(0,360)),RAD(MRANDOM(0,360)))else s.CFrame=n end for a=1,o+1 do Swait()h.Scale=h.Scale-d/o if q=="Wave"then h.Offset=VT(0,0,-h.Scale.X/8)end s.Transparency=s.Transparency-b/o if q=="Block"then s.CFrame=n*ANGLES(RAD(MRANDOM(0,360)),RAD(MRANDOM(0,360)),RAD(MRANDOM(0,360)))else s.CFrame=s.CFrame*ANGLES(RAD(e),RAD(c),RAD(f))end if p~=nil then local a=s.Orientation s.CFrame=CF(s.Position,p)*CF(0,0,-g)s.Orientation=a end end s.Transparency=1 if l==false then s:remove()else repeat Swait()until m.Playing==false s:remove()end else if l==false then s:remove()else repeat Swait()until m.Playing==false s:remove()end end end))end
-----------End of the Important stuff-----------


-----------Mouse Keybinds and stuff-----------
Mouse.Button1Down:connect(function()
	script.Parent.Remote:FireServer("Slash",1,Mouse.Hit.p)
end)
Mouse.KeyDown:connect(function(k)
	if k == "q" then
		script.Parent.Remote:FireServer("Heavy",1,nil)
	end
	if k == "e" then
		--script.Parent.Remote:FireServer("DKick",1,nil)
	end	
	if k == "r" then
		--script.Parent.Remote:FireServer("Kick",1,nil)
	end
	if k == "t" then
		script.Parent.Remote:FireServer("Inspect",1,nil)
	end
	if k == "g" then
		--script.Parent.Remote:FireServer("Clean",1,nil)
	end
	if k == "c" then
		script.Parent.Remote:FireServer("ToggleCrouch",1,nil)
	end
	if k == "f" then
		--script.Parent.Remote:FireServer("Hook",1,Mouse.Hit.p)
	end

end)

Mouse.KeyDown:connect(function (key)
	key = string.lower(key)
	if string.byte(key) == 306 then
		running = true
		script.Parent.Remote:FireServer("Run",1,nil)
		local keyConnection = Mouse.KeyUp:connect(function (key)
			if string.byte(key) == 306 then
				running = false
				script.Parent.Remote:FireServer("Walk",1,nil)
			end
		end)
		Services.Players.LocalPlayer.Character.Humanoid.WalkSpeed = 25
		repeat wait () until running == false
		keyConnection:disconnect()
		Services.Players.LocalPlayer.Character.Humanoid.WalkSpeed = 18
	end
end)

game:GetService("UserInputService").InputBegan:Connect(function(Key,Bruh)
	if Bruh then return end
	if Key.KeyCode == Enum.KeyCode.LeftControl then
		Player.Character:WaitForChild("Humanoid").WalkSpeed = 25
	end	

end)
game:GetService("UserInputService").InputEnded:Connect(function(Key,Bruh)
	if Bruh then return end

	if Key.KeyCode == Enum.KeyCode.LeftControl then
		Player.Character:WaitForChild("Humanoid").WalkSpeed = 18
	end
end)

-----------Main Tool Functions-----------

script.Parent.Equipped:Connect(function(Mouse)
	CamStatus = Player.Character:FindFirstChildOfClass("Humanoid"):WaitForChild("CamFOVStatus")
	Player.Character:WaitForChild("Humanoid"):SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
	Player.Character:WaitForChild("Humanoid"):SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
	table.insert(Walkspeedthingmongus, Player.Character:WaitForChild("Humanoid").WalkSpeed)
	Player.Character:WaitForChild("Humanoid").WalkSpeed = 20
	if triggerthing == false then
		triggerthing = true
		coroutine.resume(coroutine.create(function()
			game:GetService("RunService").RenderStepped:Connect(function()
				for i, part in pairs(Player.Character:GetChildren()) do
					if string.match(part.Name, "Arm") then
						part.LocalTransparencyModifier = 0
					--[[elseif string.match(part.Name, "Leg") then
						part.LocalTransparencyModifier = 0]]
					end
				end
			end)
			game:GetService("RunService").Heartbeat:Connect(function()
				if not Player.Character or not Player.Character:FindFirstChild("Head") then return end
				HeadFollow=true
				if HeadFollow then
					Resetted=false
					local CF=Player.Character.Head.CFrame:ToObjectSpace(Player.Character.HumanoidRootPart.CFrame*CFrame.new(0,1.5,.3))
					Player.Character:FindFirstChildOfClass("Humanoid").CameraOffset=Player.Character:FindFirstChildOfClass("Humanoid").CameraOffset:Lerp(-CF.Position,.56)
				elseif not HeadFollow and not Resetted then
					Resetted=true
					Player.Character:FindFirstChildOfClass("Humanoid").CameraOffset=Vector3.new
				end
			end)
		end))
	end
end)
script.Parent.Unequipped:Connect(function()
	TweenAnimate(Camera,{FieldOfView = 70},.2,"Back","InOut",0,false,0)	

	Player.Character:WaitForChild("Humanoid"):SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
	Player.Character:WaitForChild("Humanoid"):SetStateEnabled(Enum.HumanoidStateType.Ragdoll, true)
	Player.Character:WaitForChild("Humanoid").WalkSpeed = Walkspeedthingmongus and Walkspeedthingmongus[1] or 16
	Walkspeedthingmongus = {}
end)

-----------Main Tool Functions-----------


-----------Experimental stuff-----------

while wait() do
	local camnumber = Vector3.new(0,-1.2,0)
	if CamStatus ~= nil then
		if CamStatus.Value == "NoEFF" then
			camnumber = 77
		elseif CamStatus.Value == "Unequip" then
			camnumber = 65
		elseif CamStatus.Value == "DropKickFOV" then
			camnumber = 170
			WACKYEFFECT({Time = 30, EffectType = "Wave", Size = VT(3,.3,3), Size2 = VT(math.random(5,6),math.random(1,1.2),math.random(5,6)), Transparency = .7, Transparency2 = 1, CFrame = Player.Character.HumanoidRootPart.CFrame*CF(0,0,-1) * ANGLES(RAD(90), RAD(0), RAD(0)), MoveToPos = nil, RotationX = 0, RotationY = 10, RotationZ = 0, Material = "Neon", Color = C3(1,1,1), SoundID = nil, SoundPitch = MRANDOM(8,12)/10, SoundVolume = 6})
			WACKYEFFECT({Time = 30, EffectType = "Sphere", Size = VT(.2,.2,.2), Size2 = VT(math.random(.1,.3),math.random(8,10),math.random(.1,.3)), Transparency = .5, Transparency2 = 1, CFrame = Player.Character.HumanoidRootPart.CFrame*CF(math.random(-10,10),math.random(-10,10),math.random(-10,10)) * ANGLES(RAD(90), RAD(0), RAD(0)), MoveToPos = nil, RotationX = 0, RotationY = 0, RotationZ = 0, Material = "Neon", Color = C3(1,1,1), SoundID = nil, SoundPitch = MRANDOM(8,12)/10, SoundVolume = 6})

		elseif CamStatus.Value == "Zoom" then
			camnumber = 46
		elseif CamStatus.Value == "HookFOV" then
			camnumber = 150
			WACKYEFFECT({Time = 30, EffectType = "Sphere", Size = VT(.1,.1,.1), Size2 = VT(math.random(.1,.3),math.random(8,10),math.random(.1,.3)), Transparency = .5, Transparency2 = 1, CFrame = Player.Character.HumanoidRootPart.CFrame*CF(math.random(-10,10),math.random(-10,10),math.random(-10,10)) * ANGLES(RAD(90), RAD(0), RAD(0)), MoveToPos = nil, RotationX = 0, RotationY = 0, RotationZ = 0, Material = "Neon", Color = C3(1,1,1), SoundID = nil, SoundPitch = MRANDOM(8,12)/10, SoundVolume = 6})

		end
		TweenAnimate(Camera,{FieldOfView = camnumber+(Player.Character:WaitForChild("Humanoid").WalkSpeed/2)},.2,"Sine","InOut",0,false,0)	
	end
end





