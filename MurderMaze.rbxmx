				<Item class="LocalScript" referent="RBXA4526FF7BFF348E3BDD4CDDC8D76F97F">
					<Properties>
						<ProtectedString name="Source"><![CDATA[task.wait()
repeat task.wait() until game:IsLoaded()
--print("TEEEEEST!!!")
local plr = game:GetService("Players").LocalPlayer
plr.CameraMaxZoomDistance = 0.5
pcall(function() game:GetService("StarterGui"):SetCore("ResetButtonCallback",false) end)
local remote = game:GetService("ReplicatedStorage"):WaitForChild("Shared").Remote

local test = 0
local temp = {}

local spectateRemote = remote.ClientSpectateCall

local deathcon = remote.DeathApplication.OnClientEvent:Connect(function(model)
	print(test, "died")
	game:GetService("RunService"):BindToRenderStep("DeathCamera", 10, function(s)
		local cam = workspace.CurrentCamera
		cam.CameraType = Enum.CameraType.Scriptable
		local lom = (model:FindFirstChild("Head") and model.Head.Position) or (model:FindFirstChild("Torso") and model.Torso.Position)
		if lom then
			local cf = cam.CFrame
			local cpos = cf.Position
			local cdist = (lom - cpos).Magnitude
			local cfconst = CFrame.lookAt(lom, cpos) * CFrame.new(0,0,-cdist)
			local lookat = CFrame.lookAt(cfconst.Position, lom)
			cam.CFrame = cam.CFrame:Lerp(lookat, s*10)
		end
	end)
	task.spawn(function()
		local eq = Instance.new("EqualizerSoundEffect")
		eq.LowGain = 0
		eq.HighGain = -80
		eq.MidGain = -80
		eq.Parent = game:GetService("SoundService"):FindFirstChild("Everything")
		table.insert(temp,eq)
		local cce = Instance.new("ColorCorrectionEffect")
		cce.TintColor = Color3.new(1,0,0)
		cce.Saturation = -1
		cce.Contrast = 0
		cce.Brightness = 1
		cce.Parent = game:GetService("Lighting")
		table.insert(temp,cce)
		game:GetService("TweenService"):Create(cce, TweenInfo.new(1,Enum.EasingStyle.Linear,Enum.EasingDirection.Out), {TintColor = Color3.new(1,0,0), Brightness = 0.2}):Play()
	end)
	task.wait(0.15)
	pcall(function()
		game:GetService("SoundService"):FindFirstChild("Everything").Volume = 0
	end)
	task.wait(6)
	game:GetService("RunService"):UnbindFromRenderStep("DeathCamera")
	local cam = workspace.CurrentCamera
	cam.CameraType = Enum.CameraType.Custom
	--cam.CameraSubject = model:FindFirstChildOfClass("Humanoid")
	if not plr:GetAttribute("Playing") and game:GetService("ReplicatedStorage"):WaitForChild("Shared").GameStatus.Active.Value == true then spectateRemote:Fire("start") end
	for _,v in next, temp do pcall(game.Destroy,v) end
	if game:GetService("SoundService"):FindFirstChild("Everything") then
		game:GetService("SoundService"):FindFirstChild("Everything").Volume = 1
	end
end)

local function onChrAdded(c:Model)
	if not plr:GetAttribute("Playing") and game:GetService("ReplicatedStorage"):WaitForChild("Shared").GameStatus.Active.Value == true then spectateRemote:Fire("start") end
	repeat task.wait() until c and c:FindFirstChildOfClass("Humanoid")
	game:GetService("RunService"):UnbindFromRenderStep("DeathCamera")
	local cam = workspace.CurrentCamera
	cam.CameraType = Enum.CameraType.Custom
	cam.CameraSubject = c:FindFirstChildOfClass("Humanoid")
	for _,v in next, temp do pcall(game.Destroy,v) end
	if game:GetService("SoundService"):FindFirstChild("Everything") then
		game:GetService("SoundService"):FindFirstChild("Everything").Volume = 1
	end

	game:GetService("RunService").RenderStepped:Connect(function()
		for i, part in pairs(c:GetChildren()) do
			if string.match(part.Name, "Arm") then
				part.LocalTransparencyModifier = 0
			--[[elseif string.match(part.Name, "Leg") then
				part.LocalTransparencyModifier = 0]]
			end
		end
	end)



	local hum = c:FindFirstChildOfClass("Humanoid")
	local prevhealth = hum and hum.Health or 100
	local function onHealthChanged(newhealth)
		local diff = prevhealth - newhealth
		local percent = ((prevhealth-newhealth) / hum.MaxHealth) * 100
		local COLOR_DMG_FORMULA = math.clamp((1 - (math.floor(percent)/100) * 1.5),0,1)
		local r,g,b = 1,tonumber(COLOR_DMG_FORMULA),tonumber(COLOR_DMG_FORMULA)

		print(prevhealth, newhealth, hum.MaxHealth, "|", percent, diff)
		if percent > 5 then
			--print("The thingy recognised that you lost health", COLOR_DMG_FORMULA, Color3.new(r,g,b))
			local cce = Instance.new("ColorCorrectionEffect")
			cce.TintColor = Color3.new(r,g,b)
			cce.Saturation = .5
			cce.Parent = game:GetService("Lighting")
			game:GetService("TweenService"):Create(cce, TweenInfo.new(1,Enum.EasingStyle.Linear,Enum.EasingDirection.Out), {TintColor = Color3.new(1,1,1), Saturation = 0}):Play()
			task.delay(3,pcall,game.Destroy,cce)

			if percent >= 20 then
				local eq = Instance.new("EqualizerSoundEffect")
				eq.LowGain = 0
				eq.HighGain = -80
				eq.MidGain = -80
				eq.Parent = game:GetService("SoundService"):FindFirstChild("Everything")
				game:GetService("TweenService"):Create(eq,TweenInfo.new(0.5),{LowGain = 0, HighGain = 0, MidGain = 0}):Play()
				task.delay(3,pcall,game.Destroy,eq)
			--[[soundService:FindFirstChild("deltarune critical hit"):Play()
			plr.PlayerGui.Main.HealthContent.Effects.Vignette.ImageTransparency = 0
			local tween = tweenService:Create(plr.PlayerGui.Main.HealthContent.Effects.Vignette,TweenInfo.new(3,Enum.EasingStyle.Sine,Enum.EasingDirection.In),{ImageTransparency = 1})
			tween:Play()]]
			end
		end
		prevhealth = newhealth
	end
	local hc = hum.HealthChanged:Connect(onHealthChanged)
	hum.Destroying:Once(function()
		hc:Disconnect()
	end)
end

plr.CharacterAdded:Connect(onChrAdded)
onChrAdded(plr.Character)
]]></ProtectedString>
