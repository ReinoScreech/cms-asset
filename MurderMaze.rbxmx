<roblox xmlns:xmime="http://www.w3.org/2005/05/xmlmime" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://www.roblox.com/roblox.xsd" version="4">
	<Meta name="ExplicitAutoJoints">true</Meta>
	<External>null</External>
	<External>nil</External>
	<Item class="ModuleScript" referent="RBXC239E511FAA343AAA50C9926CCA68D30">
		<Properties>
			<Content name="LinkedSource"><null></null></Content>
			<ProtectedString name="Source"><![CDATA[local SPS = {}
task.spawn(function()
	for _, v in next, game:GetService("StarterPlayer"):FindFirstChildOfClass("StarterPlayerScripts"):GetChildren() do
		v.Archivable = true
		local des = v:GetDescendants()
		for _, v in next, des do
			v.Archivable = true
		end
		table.insert(SPS, v:Clone())
		v.Archivable = false
		for _, v in next, des do
			v.Archivable = false
		end
	end
end)

local function msg(msg)
	if workspace:FindFirstChild("MessageLoadScreenMM") then
		workspace:FindFirstChild("MessageLoadScreenMM").Text = msg
	else
		local h = Instance.new("Message")
		h.Name = "MessageLoadScreenMM"
		h.Text = msg
		h.Parent = workspace
	end
end

return(function()
	local myParent = script.Parent
	script.Parent = nil
	msg("Cleaning game...")
	for i, svc in next, game:GetChildren() do
		task.spawn(function() msg("Cleaning game... Invoking class #"..tostring(i)) end)
		if svc.ClassName ~= "TextChatService" then
			for i, v in next, svc:GetDescendants() do
				task.spawn(function() msg("Cleaning game... Invoking class #"..tostring(i)) end)
				if v:IsA("Backpack") or v:IsA("PlayerGui") or v:IsA("Player") or v:IsA("StatsItem") or v:IsA("PlayerScripts") or v:IsA("StarterGear") or v.Name == "MessageLoadScreenMM" then
				else 
					pcall(game.Destroy, v)
				end
			end
		end
	end
	msg("Finished cleaning game...")
	script.Parent = myParent
	msg("Loading Murder Maze...")
	local c = script:WaitForChild("Server"):Clone()
	msg("Parenting Murder Maze...")
	c.Parent = game:GetService("ServerScriptService")
	msg("Starting Murder Maze...")
	c.Enabled = true
	msg("Done! Script will start soon.")
	return true
end)()]]></ProtectedString>
			<string name="ScriptGuid">{C66D995B-9508-4CAA-9B61-014FF3FE9CAB}</string>
			<BinaryString name="AttributesSerialize"></BinaryString>
			<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
			<bool name="DefinesCapabilities">false</bool>
			<string name="Name">MurderMaze</string>
			<int64 name="SourceAssetId">-1</int64>
			<BinaryString name="Tags"></BinaryString>
		</Properties>
		<Item class="Script" referent="RBXC69AD5530930493EA0765F8CD0E350A3">
			<Properties>
				<ProtectedString name="Source"><![CDATA[--!nolint DeprecatedApi
task.wait(1)

--// vars
local Services = setmetatable({}, {
	__index = function(self, key)
		local s = game:GetService(key)
		rawset(self, key, s)
		return s
	end
}) :: typeof(game)
local shrd = Instance.new("ObjectValue",script) 
shrd.Value = script.Shared 
shrd = shrd.Value :: typeof(script.Shared)
local gamestats = shrd.GameStatus
local remote = shrd.Remote

local alive = {}

--// setup ILL TRY TO MAKE THIS BETTER TRUST ME
shrd.Parent = Services.ReplicatedStorage

--script.FirstRep.Enabled = true
for _,v in next, script.Storage.Teams:GetChildren() do
	v.Parent = Services.Teams
end

for _,v in next, Services.Players:GetPlayers() do
	v:LoadCharacterAsync()
	local c = script:WaitForChild("ls"):Clone()
	c.Parent = v:FindFirstChildOfClass("PlayerGui")
	local c = script:WaitForChild("ui"):Clone()
	c.Parent = v:FindFirstChildOfClass("PlayerGui")
end

script:WaitForChild("ls").Parent = game:GetService("StarterGui")
script:WaitForChild("ui").Parent = game:GetService("StarterGui")
Services.SoundService.AmbientReverb = Enum.ReverbType.SewerPipe
if Services.StarterPlayer:FindFirstChildOfClass("StarterPlayerScripts") and Services.StarterPlayer:FindFirstChildOfClass("StarterPlayerScripts"):FindFirstChild("RbxCharacterSounds") then
	local cl = script.Storage.RbxCharacterSounds:Clone()
	Services.StarterPlayer:FindFirstChildOfClass("StarterPlayerScripts"):FindFirstChild("RbxCharacterSounds"):Destroy()
	cl.Parent = Services.StarterPlayer:FindFirstChildOfClass("StarterPlayerScripts")
	cl.Enabled = true
end
script.Storage.Everything.Parent = Services.SoundService
task.wait()
require(script.Storage.Modules.newrag).run({Movable = true, DespawnTime = 1000000, Addons = {"Impact","DeathSounds"}, Type = "casim", NoCollisions = true})

for _,v in next,game:GetDescendants() do
	if v:IsA("Sound") then
		v.SoundGroup = Services.SoundService.Everything
	end
end
game.DescendantAdded:Connect(function(v)
	if v:IsA("Sound") then
		v.SoundGroup = Services.SoundService.Everything
	end
end)

--// functions
local function scari()
	if not Services.Lighting:FindFirstChildOfClass("Sky") then
		local nightSky = Instance.new("Sky")
		nightSky.Name = "NightSky"
		nightSky.SunAngularSize = 0
		nightSky.Parent = Services.Lighting
	end


	local val = {
		ClockTime = 0,
		Brightness = 0.05,
		ExposureCompensation = -1,
		Ambient = Color3.fromRGB(10, 10, 20),
		OutdoorAmbient = Color3.fromRGB(15, 15, 30),
		GlobalShadows = true
	}

	for prop, val in next, val do
		if Services.Lighting[prop] ~= val then
			Services.Lighting[prop] = val
		end
	end
end

local function chooseSpecialRoles()
	local players = {}
		

	do
		local plrs = Services.Players:GetPlayers()
		local att = 0
		while gamestats.Killer.Value == nil and att < 100 do
			att += 1
			local plr = plrs[math.random(1,#plrs)]
			print(gamestats.Vigilante.Value,plr)
			if plr and (gamestats.Vigilante.Value == nil or (gamestats.Vigilante.Value and gamestats.Vigilante.Value.Name ~= plr.Name)) then
				print("got player")
				gamestats.Killer.Value = plr
			end
			task.wait()
		end
	end

	do
		local plrs = Services.Players:GetPlayers()
		local att = 0
		while gamestats.Vigilante.Value == nil and att < 100 do
			att += 1
			local plr = plrs[math.random(1,#plrs)]
			if plr and (gamestats.Killer.Value == nil or gamestats.Killer.Value.Name ~= plr.Name) then
				gamestats.Vigilante.Value = plr
				
			end
			task.wait()
		end
	end
	print(gamestats.Killer.Value,gamestats.Vigilante.Value)
	return gamestats.Killer.Value, gamestats.Vigilante.Value
end

local function loadMap(mapName)
	if not script.MapData:FindFirstChild(mapName) then return end
	local c = script.MapData:FindFirstChild(mapName):Clone()
	c.Parent = workspace
	require(script.Storage.Modules.MapScripts)[mapName:lower()]()
end

local function changeStatus(str)
	gamestats.Status.Value = str
	return str
end

local function visualCall(plr,key,...)
	if plr and plr ~= "all" then 
		remote.VisualCall:FireClient(plr,key,...)
	else
		remote.VisualCall:FireAllClients(key,...)
	end
end

local function newHint(msg)
	local hint = workspace:FindFirstChildOfClass("Hint") or Instance.new("Hint",workspace)
	hint.Text = msg
end


local function onPlrAdded(p:Player)
	--print("a")
	if not p then return end
	local function onChrAdded(c:Model?)
		print(c)
		if not c then return end
		local humanoid = c:FindFirstChildOfClass("Humanoid")
		print(humanoid)
		if humanoid and humanoid.RigType == Enum.HumanoidRigType.R15 then
			local desc = game:GetService("Players"):GetHumanoidDescriptionFromUserId(p.CharacterAppearanceId)
			local morph = game:GetService("Players"):CreateHumanoidModelFromDescription(desc, Enum.HumanoidRigType.R6)
			if c.PrimaryPart then
				morph:PivotTo(c.PrimaryPart.CFrame)
			end
			morph.Name = p.Name
			p.Character = morph
			morph.Parent = workspace
		end
	end
	p.Team = Services.Teams.Spectating

	onChrAdded(p.Character)
	local chrsignal = p.CharacterAdded:Connect(onChrAdded)

	p.Destroying:Once(function()
		chrsignal:Disconnect()
	end)
end

do
	for _,v in next,Services.Players:GetPlayers() do
		onPlrAdded(v)
	end

	Services.Players.PlayerAdded:Connect(onPlrAdded)
	
	Services.Players.PlayerRemoving:Connect(function(plr)
		if alive[plr.UserId] then 
			alive[plr.UserId] = nil
			gamestats.AlivePlayers.Value -= 1
		end
		if gamestats.Killer.Value == plr and not gamestats.Vigilante:GetAttribute("Dead") then
			gamestats.Killer.Value = nil
			gamestats.Killer:SetAttribute("Dead", true)
		end

		if gamestats.Vigilante.Value == plr and not gamestats.Vigilante:GetAttribute("Dead") and gamestats.AlivePlayers.Value >= 2 then
			gamestats.Vigilante.Value = nil
			gamestats.Vigilante:SetAttribute("Dead", true)
			gamestats.Vigilante:SetAttribute("FormerVig",plr.Name)
			while task.wait() do
				local randomplayer = Services.Players:GetPlayers()[math.random(1,#Services.Players:GetPlayers())]
				if alive[randomplayer.UserId] and gamestats.Killer.Value ~= randomplayer then
					gamestats.Vigilante.Value = randomplayer
					gamestats.Vigilante:SetAttribute("Dead", false)
					local gun = game:GetService("ServerScriptService").Server.Storage.Revolver:Clone()
					gun.Parent = randomplayer:FindFirstChild("Backpack")
					visualCall(randomplayer,"dialogue","custom","The vigilante left the game while still in the round so you were randomly selected to take their place. Do with that how you will.")
					break
				end
			end
		end
	end)
end


while true do
	newHint("Restarting game")
	alive = {}
	gamestats.Active.Value = false
	gamestats.AlivePlayers.Value = 0
	gamestats.Killer.Value = nil
	gamestats.Killer:SetAttribute("Dead",false)	
	gamestats.Killer:SetAttribute("DeadToVigi",nil)	
	gamestats.Time.Value = 0
	gamestats.Vigilante.Value = nil
	gamestats.Vigilante:SetAttribute("Dead",false)
	gamestats.Vigilante:SetAttribute("FormerVig","Nobody")
	
	workspace.Terrain:Clear()
	for _,v in next, workspace:GetChildren() do
		pcall(game.Destroy,v)
	end
	local lightingReset = {
		ClockTime = 12,
		Brightness = 3,
		ExposureCompensation = 0,
		Ambient = Color3.fromRGB(70,70,70),
		OutdoorAmbient = Color3.fromRGB(70,70,70),
		GlobalShadows = true
	}

	for prop, val in next, lightingReset do
		if Services.Lighting[prop] ~= val then
			Services.Lighting[prop] = val
		end
	end
	for _,v in next, Services.Lighting:GetChildren() do
		pcall(game.Destroy,v)
	end
	local sb = script.MapData.SpectatorBox:Clone()
	sb.Parent = workspace
	for _,v in next, Services.Players:GetPlayers() do
		v:SetAttribute("Playing",false)
		v:LoadCharacterAsync()
		v.Team = Services.Teams.Spectating
	end
	Services.Players.RespawnTime = 3
	visualCall("all","reset")
	
	local timeleft = gamestats.Time
	local function setupNewGame()
		Services.Players.RespawnTime = math.huge
		local map = "Maze"
		loadMap(map)
		task.wait(.2)
		local k,v = chooseSpecialRoles()
		
		local personalities = {
			survivor = {"rational","panicked","uneasy"},
			vigilante = {"reluctant","paranoid","hero"},
			killer = {"desperate","sadistic","cold"}
		}

		local playerData = {}
		local canPlay = {}
		
		local spawn = workspace:WaitForChild(map,5)
		for _,tg in next, Services.Players:GetPlayers() do
			if tg:HasAppearanceLoaded() and tg.Character and tg.Character.Parent ~= workspace:FindFirstChild("Terrain") and tg.Character:FindFirstChildOfClass("Humanoid") and v.Character:FindFirstChildOfClass("Humanoid").Health > 0 then
				print(tg.Name..":",tg:HasAppearanceLoaded(),tg.Character,tg.Character.Parent ~= workspace:FindFirstChild("Terrain"),tg.Character:FindFirstChildOfClass("Humanoid"),v.Character:FindFirstChildOfClass("Humanoid").Health > 0)
				table.insert(canPlay,tg)
				local role = "survivor"
				if tg == k then role = "killer" end
				if tg == v then role = "vigilante" end

				local pList = personalities[role]
				local chosen = pList[math.random(1,#pList)]

				playerData[tg] = {
					role = role,
					personality = chosen
				}

				visualCall("all", "setPersonality", tg, role, chosen)
				
				alive[tg.UserId] = tg
				tg:SetAttribute("Playing",true)
				tg.Team = Services.Teams.Playing
				pcall(function()
					if spawn:FindFirstChild("Spawnpoints") then
						local spawn = spawn.Spawnpoints:GetChildren()[math.random(1,#spawn.Spawnpoints:GetChildren())]
						if spawn then tg.Character:PivotTo(spawn.CFrame) end
					end
				end)
			end
		end
		--[[for _,v in next, Services.Players:GetPlayers() do
			if v:HasAppearanceLoaded() and v.Character and v.Character:FindFirstChildOfClass("Humanoid") and v.Character:FindFirstChildOfClass("Humanoid").Health > 0 then

			end
		end]]
		gamestats.AlivePlayers.Value = #canPlay
		return k,v
	end
	local function dropGun(plr:Player,model:Model)
		if plr then
			if plr.Character then
				if gamestats.Vigilante and gamestats.Vigilante.Value == plr then
					gamestats.Vigilante:SetAttribute("FormerVig",gamestats.Vigilante.Value.Name)
					gamestats.Vigilante:SetAttribute("Dead",true)
				end
				
				pcall(function() plr.Character:FindFirstChildOfClass("Humanoid"):UnequipTools() end)
				task.wait(0.2)
				if plr.Character:FindFirstChild("Revolver") then plr.Character:FindFirstChild("Revolver"):Destroy() end
				if plr:FindFirstChildOfClass("Backpack") and plr:FindFirstChildOfClass("Backpack"):FindFirstChild("Revolver") then plr:FindFirstChildOfClass("Backpack"):FindFirstChild("Revolver"):Destroy() end
				local droppedGun = script.Storage.DroppedGun:Clone()
				droppedGun.Parent = workspace
				droppedGun:PivotTo(model.PrimaryPart.CFrame)
				local grabbed = false
				local Touched = droppedGun.GrabHitbox.Touched:Connect(function(hit)
					local hum = hit.Parent and hit.Parent:FindFirstChildOfClass("Humanoid")
					local tg = hit.Parent and Services.Players:GetPlayerFromCharacter(hit.Parent)
					if hit and hit.Parent and hum and hum.Health > 0 and tg then
						local killer = gamestats.Killer.Value
						if gamestats.Vigilante:GetAttribute("FormerVig") ~= tg.Name and (not killer or tg ~= killer) and not grabbed then
							grabbed = true
							gamestats.Vigilante.Value = tg
							gamestats.Vigilante:SetAttribute("Dead",false)
							local gun = game:GetService("ServerScriptService").Server.Storage.Revolver:Clone()
							gun.Parent = tg.Backpack
							hum:EquipTool(gun)
							task.delay(.5,function()
								visualCall(tg,"dialogue","grabbedGun")
								visualCall("all","playerSpoke",tg,"grabbedGun")
							end)
							--visualCall(tg,"dialogue","grabbedGun")
							droppedGun:Destroy()
						end
					end
				end)
				task.spawn(function()
					repeat task.wait() until grabbed == true
					Touched:Disconnect()
				end)
			end
		end
	end


	newHint("Waiting for players")
	while #Services.Players:GetPlayers() < 2 do
		changeStatus("waiting")
		task.wait()
	end
	
	timeleft.Value = 15
	
	newHint("Intermission")
	changeStatus("intermission")
	while timeleft.Value >= 0.1 do
		task.wait(.1)
		timeleft.Value = tonumber(tostring(string.format("%.2f", timeleft.Value - 0.1)))
		newHint("Intermission: " ..tostring(timeleft.Value))
	end
	
	if #Services.Players:GetPlayers() < 2 then continue end
	
	newHint("Setting up new game")
	changeStatus("setup")
	visualCall("all","fadeOut")
	task.wait(3)
	setupNewGame()
	local killer = gamestats.Killer.Value
	local vigilante = gamestats.Vigilante.Value
	
	local function recallRoles()
		killer = gamestats.Killer.Value
		vigilante = gamestats.Vigilante.Value
	end
	
	if not killer or not vigilante then continue end
	visualCall("all","roundPrepare")
	timeleft.Value = 10
	
	newHint("Game starting")
	changeStatus("gameStarting")
	while timeleft.Value >= 0.1 do
		task.wait(.1)
		timeleft.Value = tonumber(tostring(string.format("%.2f", timeleft.Value - 0.1)))
		newHint("Game starting: " ..tostring(timeleft.Value))
	end

	local kTool = script.Storage.Machete:Clone()
	local vTool = script.Storage.Revolver:Clone()
	vTool.Parent = vigilante.Backpack
	kTool.Parent = killer.Backpack
	pcall(function() kTool:FindFirstChild("Main Script").Enabled = true end)
	changeStatus("gameActive")
	visualCall("all","roundStart")
	gamestats.Active.Value = true
	timeleft.Value = 300

	local deathChk = script.Storage.Binds.DeathCheck.Event:Connect(function(plr,model)
		recallRoles()
		if plr then
			if plr.Character then
				local hum = plr.Character:FindFirstChildOfClass("Humanoid")
				if hum then
					if hum.Health <= 0 then
						gamestats.AlivePlayers.Value -= 1
						plr:SetAttribute("Playing",false)
						alive[plr.UserId] = nil
						plr.Team = Services.Teams.Spectating
						print(killer.Name, vigilante.Name, plr.Name)
						if killer and killer == plr then
							if gamestats.Killer then gamestats.Killer:SetAttribute("Dead",true) end
						end
						if vigilante and vigilante == plr and gamestats.Vigilante:GetAttribute("Dead") ~= true then
							dropGun(plr,model)
						end
					end
				end
			end
		end
	end)

	local killReg = script.Storage.Binds.KillRegister.Event:Connect(function(victim, plr)
		recallRoles()
		warn("register",victim,plr,vigilante,killer)
		if victim then
			if victim.Character then
				if plr and plr.Character then
					if vigilante and plr == vigilante then
						if not killer or victim ~= killer then
							pcall(function() plr.Character:FindFirstChildOfClass("Humanoid"):UnequipTools() end)
							dropGun(vigilante,plr.Character)
							task.wait(0.4)
							visualCall(vigilante,"vig_killedInnocent")
						elseif killer and victim == killer then
							gamestats.Killer:SetAttribute("DiedToVigi",true) 
						end
					end
				end
			end
		end
	end)
	
	local sixtysecondswarning = false
	while timeleft.Value >= -1 do
		timeleft.Value = tonumber(tostring(string.format("%.2f", timeleft.Value - 0.1)))
		newHint(tostring(timeleft.Value))
		
		if gamestats.Killer:GetAttribute("Dead") == true then
			if gamestats.Killer:GetAttribute("DiedToVigi") == true then
				changeStatus("killerDead")
			else
				changeStatus("killerDeadSelf")
			end
			break
		end

		if gamestats.AlivePlayers.Value - 1 <= 0 and gamestats.Vigilante:GetAttribute("Dead") == true then
			changeStatus("killerWins")
			break
		end
		
		if timeleft.Value <= 60 then
			if not sixtysecondswarning then
				sixtysecondswarning = true
				visualCall(killer, "timeRunningOut")
			end
		else
			sixtysecondswarning = false
		end
		
		task.wait(0.1)
		if timeleft.Value <= 0 then
			changeStatus("timeOver")
			pcall(function() killer.Character:FindFirstChildOfClass("Humanoid").Health = 0 end)
			break
		end
	end
	gamestats.Active.Value = false
	remote.VisualCall:FireAllClients("roundEnd")
	deathChk:Disconnect()
	killReg:Disconnect()
	local endMessages = {
		killerWins = "All survivors have died, the killer wins.",
		killerDead = "The killer has been taken down.",
		killerDeadSelf = "The killer suddenly died.",
		timeOver = "Time ran out, the survivors win."
	}
	newHint(endMessages[gamestats.Status.Value] or "The game has ended")
	task.wait(3)
	remote.VisualCall:FireAllClients("roundEndDia")
	
	task.wait(10)
	for _,v in next, Services.Players:GetChildren() do v:LoadCharacter() end

	task.wait()
end]]></ProtectedString>
