									<ProtectedString name="Source"><![CDATA[local f = {}
local Addons = script.Parent:FindFirstChild("Addons")
local Rigs = require(script.RigTypes)
local plrs = game:GetService("Players")

local tag = require(game:GetService("ServerScriptService").Server.Storage.Modules.Tagging)


local directory = (script:GetAttribute("RagdollType") and Rigs[string.lower(script:GetAttribute("RagdollType"))]) or Rigs.default

--// Create attachments
function f.buildattachments(model:Model)
	local attachmentDirectory = {}

	for name, data in pairs(directory.Attachments) do
		if not data then return end
		if model:FindFirstChild(name) then
			attachmentDirectory[name] = {}

			local C0 = model:FindFirstChild(tostring(data.C0.Name), true) or Instance.new("Attachment")
			for prop, val in pairs(data.C0) do
				if prop ~= "Parent" then
					C0[prop] = val
				end
			end
			C0.Parent = model:FindFirstChild(data.C0.Parent)
			attachmentDirectory[name].C0 = C0

			local C1 = model:FindFirstChild(tostring(data.C1.Name), true) or Instance.new("Attachment")
			for prop, val in pairs(data.C1) do
				if prop ~= "Parent" then
					C1[prop] = val
				end
			end
			C1.Parent = model:FindFirstChild(data.C1.Parent)
			attachmentDirectory[name].C1 = C1
		end
	end
	return attachmentDirectory
end

--// Death function
function f.ondeath(chr:Model)
	--print(chr)
	local plr = plrs:GetPlayerFromCharacter(chr)
	local hum:Humanoid = chr:FindFirstChildOfClass("Humanoid")

	chr.Archivable = true
	local chrc:Model = hum.RigType == Enum.HumanoidRigType.R15 and game:GetService("ReplicatedStorage"):FindFirstChild("DefaultCharacter"):Clone() or chr:Clone()
	chrc.Name = `{chr}_`

	local chum = chrc:FindFirstChildOfClass("Humanoid")
	if chum ~= nil then
		chum.PlatformStand = true
		chum.Sit = true 
		chum.MaxHealth = 0
		chum.Health = 0
		chum.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
	end

	chrc.Parent = game:GetService("Workspace")
	local primary = chr.PrimaryPart or chr:FindFirstChild("Torso") or chr:FindFirstChild("LowerTorso") 
	--print(primary)
	if not primary then return end
	if hum.RigType == Enum.HumanoidRigType.R15 then
		chrc:WaitForChild("Humanoid"):ApplyDescription(hum:FindFirstChildOfClass("HumanoidDescription"), Enum.AssetTypeVerification.Always)
		task.wait()
		--print(chr,chrc)
		chrc:PivotTo(primary.CFrame)
	end
	--print(chrc,chrc.Parent)
	--chr.Archivable = false

	for _,obj:Instance in pairs(chrc:GetDescendants()) do
		if obj:IsA("Motor6D") and obj.Parent == chrc:FindFirstChild("Torso") then
			obj:Destroy()
		end 
		local invalidations = {"BodyVelocity", "AngularVelocity", "LinearVelocity", "BodyAngularVelocity", "BodyThrust", "BodyGyro", "BodyForce", "BodyMover"}
		task.delay(0.2, function()
			if table.find(invalidations, tostring(obj.ClassName)) then
				task.defer(pcall, game.Destroy, obj)
			end
		end)
		if obj:IsA("BallSocketConstraint") or obj:IsA("HingeConstraint") or obj:IsA("Glue") or obj:IsA("LocalScript") or obj:IsA("Script") or obj:IsA("ForceField") or obj.Name == "FW" or obj.Name == "Revolver" or (obj:IsA("Weld") and string.match(obj.Name,"Shoulder")) or (obj:IsA("LuaSourceContainer") and script.Name == "Health") then
			obj:Destroy()
		end
		task.delay(0.5, function()
			if obj:IsA("ParticleEmitter") then
				obj.Enabled = false
			end
		end)
	end

	task.delay(script.DelayValue.Value,pcall,game.Destroy,chrc)
	task.spawn(function()
		pcall(function() 
			local tagged,object = tag.IsTagged(chr)
			local plr = game:GetService("Players"):GetPlayerFromCharacter(chr)
			print(tagged,plr,object,object and object.Value or "no value")
			if tagged and plr and object and object.Value then 
				local tagger = game:GetService("Players"):GetPlayerFromCharacter(object.Value)
				task.spawn(function() 
					if tagger then game:GetService("ServerScriptService").Server.Storage.Binds.KillRegister:Fire(plr,tagger) end
				end) 
			end
			task.spawn(function() game:GetService("ServerScriptService").Server.Storage.Binds.DeathCheck:Fire(game:GetService("Players"):GetPlayerFromCharacter(chr),chrc) end)
			task.spawn(function() game:GetService("ReplicatedStorage").Shared.Remote.DeathApplication:FireClient(game:GetService("Players"):GetPlayerFromCharacter(chr),chrc) end)
		end)
	end)
	

	local collisionsDirectory = directory["Collisions"]
	local co = game:GetService("ReplicatedStorage"):FindFirstChild("PlatformStandCollisions"):Clone()
	if not collisionsDirectory["HCollision"] and co:FindFirstChild("HCollision") then pcall(game.Destroy,co.HCollision) end
	
	co.Parent = chrc

	if not collisionsDirectory then
		if chrc:FindFirstChild("Right Arm") then co.RAPSCollision.Weld.Part1 = chrc:WaitForChild("Right Arm") end
		if chrc:FindFirstChild("Left Arm") then co.LAPSCollision.Weld.Part1 = chrc:WaitForChild("Left Arm") end
		if chrc:FindFirstChild("Right Leg") then co.RLPSCollision.Weld.Part1 = chrc:WaitForChild("Right Leg") end
		if chrc:FindFirstChild("Left Leg") then co.LLPSCollision.Weld.Part1 = chrc:WaitForChild("Left Leg") end
	else
		if collisionsDirectory["HCollision"] and chrc:FindFirstChild(collisionsDirectory["HCollision"].Part) then chrc:FindFirstChild(collisionsDirectory["HCollision"].Part).CanCollide = false end
		for name, data in pairs(collisionsDirectory) do
			local part = co:FindFirstChild(name)
			if not part then continue end
			local weld, limb = part:FindFirstChildOfClass("Weld"), chrc:FindFirstChild(data.Part)
			if not weld or not limb then continue end

			weld.Part1 = limb
			--print(data,part,weld,limb)
			if data.SizeTable == true and data.Size["UsingPartSize"] == true then
				local multi = data.Size["Multiplier"]
				part.Size = limb.Size * multi
			else
				part.Size = data.Size or Vector3.new(0.7,0.7,0.7)
			end

			if data.C0 then
				weld.C0 = data.C0
			end
			if data.C1 then
				weld.C1 = data.C1
			end

			if data.Shape then
				part.Shape = data.Shape
			end
		end
	end
	if script:GetAttribute("NoCollisions") == true then
		for _,coinst in pairs(co:GetChildren()) do
			if coinst:FindFirstChildOfClass("Weld") then
				local collision = Instance.new("NoCollisionConstraint")
				collision.Part0 = chrc:FindFirstChild("Torso")
				collision.Part1 = coinst

				collision.Parent = coinst
			end
		end
	end

	for _,v in pairs(chr:GetChildren()) do
		if v:IsA("Part") or v:IsA("Hat") or v:IsA("MeshPart") or v:IsA("ForceField") then
			v:Destroy()
		end
	end
	game:GetService("Debris"):AddItem(chr,7) -- fallback 

	local attachments = f.buildattachments(chrc)
	for limbStr, socket in pairs(directory.Sockets) do
		local limb = chrc:FindFirstChild(limbStr)
		if not limb then continue end
		if not attachments or (not attachments[limbStr].C0 or not attachments[limbStr].C1) then continue end

		local constraint = Instance.new("BallSocketConstraint")
		constraint.Name = "RagdollConstraint"
		constraint.Attachment0 = attachments[limbStr].C0
		constraint.Attachment1 = attachments[limbStr].C1

		for prop, val in pairs(socket) do
			constraint[prop] = val
		end

		constraint.Parent = limb
		constraint.Enabled = true
	end
	local rootweld = Instance.new("WeldConstraint")
	rootweld.Part0 = chrc:FindFirstChild("Torso")
	rootweld.Part1 = chrc:FindFirstChild("HumanoidRootPart")
	rootweld.Name = "RagdollRootWeld"
	rootweld.Enabled = true
	rootweld.Parent = chrc:FindFirstChild("HumanoidRootPart")
	
	if Addons then
		if Addons:FindFirstChild("Impact") then
			local im = script.Impact:Clone()
			im.Parent = chrc
			im.Enabled = true
		end
		if Addons:FindFirstChild("DeathSounds") then
			pcall(function() require(script:FindFirstChild("DeathSounds"))(chrc) end)
		end
	end

	if chrc:FindFirstChild("HumanoidRootPart") and chrc.HumanoidRootPart:FindFirstChild("RootJoint") then
		chrc.HumanoidRootPart.RootJoint:Destroy()
	end

	if script.Movable.Value == true then
		local dragger = Instance.new("DragDetector",chrc)
		dragger.Name = "Grabbable"
		dragger.DragStyle = Enum.DragDetectorDragStyle.TranslateViewPlane
		dragger.Enabled = true
		dragger.Responsiveness = 20
		dragger.MaxActivationDistance = 25
	end

	local cam = script:FindFirstChild("Camera"):Clone()
	cam:WaitForChild("Obj").Value = chrc:FindFirstChild("Head") and chrc.Head or chrc.PrimaryPart
	cam.Enabled = true
	cam.Parent = chr
	chr.Parent = workspace:FindFirstChild("Terrain")
	local deny = script:FindFirstChild("Denyers"):Clone()
	deny.Parent = chrc
	deny.Enabled = true


	local a = coroutine.create(function()
		while task.wait() do
			if not chrc then break end
			if chrc:FindFirstChild("HumanoidRootPart") then
				chrc.HumanoidRootPart.CanCollide = false
			end
			chum.PlatformStand = true
		end
	end)
	coroutine.resume(a)
end

return f
]]></ProtectedString>
